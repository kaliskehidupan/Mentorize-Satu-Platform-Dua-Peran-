<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================== LIST MENTOR ======================== -->
    <template id="page_list_mentor" name="List Mentor">
        <t t-call="web.layout">
            <t t-set="head">
                <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
            </t>
            <main class="mtz-app-page">
                <nav class="mtz-app-nav mtz-animate-down">
                    <a href="/mentorize/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
                    <div class="mtz-app-menu">
                        <a href="/mentorize/dashboard">Dashboard</a>
                        <a href="/mentorize/mentor" class="active">Cari Mentor</a>
                        <a href="/mentorize/recommendations">Rekomendasi</a>
                        <a href="/mentorize/history">Riwayat</a>
                        <a href="/mentorize/profile">Profil</a>
                    </div>
                    <div class="mtz-user-chip">
                        <span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></span>
                        <span><b t-esc="user.name"/><small>Mahasiswa</small></span>
                    </div>
                </nav>

                <section class="mtz-dashboard-shell">
                    <div class="mtz-panel mtz-animate-up">
                        <div class="mtz-panel-header">
                            <div>
                                <h2>Cari Mentor</h2>
                                <p>Temukan mentor terbaik yang sesuai dengan kebutuhan kamu</p>
                            </div>
                            <a href="/mentorize/recommendations" class="mtz-btn-primary mtz-btn-fit">✨ Lihat Rekomendasi untuk Saya</a>
                        </div>

                        <!-- Filter Skill -->
                        <div class="mtz-search-card">
                            <span class="mtz-filter-label">Filter Skill:</span>
                            <div class="mtz-filter-chips" style="display: flex; gap: 8px; flex-wrap: wrap;">
                                <a href="/mentorize/mentor" class="mtz-state info" style="background: var(--mtz-primary); color: white;">Semua</a>
                                <t t-foreach="skills" t-as="skill">
                                    <a t-attf-href="/mentorize/mentor?skill=#{skill.id}" class="mtz-state muted">
                                        <t t-esc="skill.name"/>
                                    </a>
                                </t>
                            </div>
                        </div>

                        <!-- Grid Mentor -->
                        <div class="mtz-mentor-grid mtz-animate-up mtz-delay-1">
                            <t t-foreach="alumni_list" t-as="alumni">
                                <article class="mtz-mentor-card">
                                    <t t-if="matchmaking_data.get(alumni.id, {}).get('is_recommended')">
                                        <div class="mtz-state success" style="margin-bottom: 12px;">⭐ Direkomendasikan</div>
                                    </t>
                                    <div class="mtz-mentor-top">
                                        <span class="mtz-avatar-circle"><t t-esc="alumni.name and alumni.name[:1].upper() or 'A'"/></span>
                                        <div>
                                            <h3 t-esc="alumni.name"/>
                                            <p t-esc="alumni.pekerjaan or alumni.tempat_bekerja or 'Alumni Mentor'"/>
                                        </div>
                                        <span class="mtz-rating">★ <t t-esc="'%.1f' % alumni.rating"/></span>
                                    </div>
                                    <p class="mtz-mentor-desc" t-esc="alumni.deskripsi or 'Siap membantu proses mentoring dan pengembangan karier mahasiswa.'"/>
                                    <div class="mtz-badge-list">
                                        <t t-foreach="alumni.skill_ids[:3]" t-as="skill">
                                            <span class="mtz-badge-skill" t-esc="skill.name"/>
                                        </t>
                                        <t t-if="len(alumni.skill_ids) > 3">
                                            <span class="mtz-badge-skill">+<t t-esc="len(alumni.skill_ids) - 3"/></span>
                                        </t>
                                    </div>
                                    <t t-if="matchmaking_data.get(alumni.id)">
                                        <div class="mtz-mini-stats" style="margin: 12px 0;">
                                            <span>🎯 <t t-esc="matchmaking_data[alumni.id]['skill_match']"/> skill cocok</span>
                                        </div>
                                    </t>
                                    <div class="mtz-mentor-actions" style="margin-top: 16px;">
                                        <a t-attf-href="/mentorize/mentor/#{alumni.id}" class="mtz-btn-primary">Lihat Profil</a>
                                    </div>
                                </article>
                            </t>
                            <t t-if="not alumni_list">
                                <div class="mtz-empty-state full">
                                    <b>🔍 Belum ada mentor tersedia</b>
                                    <p>Coba lagi nanti atau ubah filter pencarian</p>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </main>
        </t>
    </template>

    <!-- ======================== DETAIL MENTOR ======================== -->
    <template id="page_detail_mentor" name="Detail Mentor">
        <t t-call="web.layout">
            <t t-set="head">
                <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
            </t>
            <main class="mtz-app-page">
                <nav class="mtz-app-nav mtz-animate-down">
                    <a href="/mentorize/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
                    <div class="mtz-app-menu">
                        <a href="/mentorize/dashboard">Dashboard</a>
                        <a href="/mentorize/mentor" class="active">Cari Mentor</a>
                        <a href="/mentorize/recommendations">Rekomendasi</a>
                        <a href="/mentorize/history">Riwayat</a>
                        <a href="/mentorize/profile">Profil</a>
                    </div>
                    <div class="mtz-user-chip">
                        <span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></span>
                        <span><b t-esc="user.name"/><small>Mahasiswa</small></span>
                    </div>
                </nav>

                <section class="mtz-dashboard-shell mtz-narrow-shell">
                    <a href="/mentorize/mentor" class="mtz-back-link" style="display: inline-block; margin-bottom: 18px;">← Kembali ke Daftar Mentor</a>

                    <div class="mtz-profile-hero">
                        <div class="mtz-profile-avatar"><t t-esc="alumni.name and alumni.name[:1].upper() or 'A'"/></div>
                        <div class="mtz-profile-title">
                            <h1 t-esc="alumni.name"/>
                            <p t-esc="alumni.pekerjaan or alumni.tempat_bekerja or 'Alumni Mentor'"/>
                            <div class="mtz-badge-list">
                                <span t-attf-class="mtz-state #{alumni.ketersediaan == 'available' and 'success' or (alumni.ketersediaan == 'busy' and 'info' or 'muted')}">
                                    <t t-if="alumni.ketersediaan == 'available'">🟢 Tersedia</t>
                                    <t t-elif="alumni.ketersediaan == 'busy'">🟡 Sibuk</t>
                                    <t t-else="">🔴 Offline</t>
                                </span>
                                <span class="mtz-state info">⭐ <t t-esc="'%.1f' % alumni.rating"/> Rating</span>
                                <span class="mtz-state muted">📅 Lulus <t t-esc="alumni.tahun_lulus or '-'"/></span>
                            </div>
                        </div>
                    </div>

                    <div class="mtz-dashboard-grid" style="grid-template-columns: 1fr 2fr; gap: 24px;">
                        <!-- Left sidebar -->
                        <div class="mtz-panel">
                            <div class="mtz-panel-header compact"><div><h2>Statistik</h2></div></div>
                            <div class="mtz-mini-stats">
                                <span><b t-esc="alumni.slot_mentoring"/> Slot tersisa</span>
                                <span><b>🎯 <t t-esc="match_info.score if match_info else 0"/>%</b> Kecocokan</span>
                            </div>
                            <t t-if="match_info">
                                <div class="mtz-progress-bar-wrap" style="margin: 16px 0;">
                                    <div class="mtz-progress-bar" t-attf-style="width: #{min(100, match_info.get('score', 0))}%"/>
                                </div>
                                <p><b><t t-esc=" match_info.skill_match if match_info else 0"/></b> skill cocok</p>
                            </t>

                            <t t-if="mahasiswa">
                                <t t-if="existing_request">
                                    <div class="mtz-alert-info mtz-state info" style="margin-top: 16px; text-align: center;">
                                        <t t-if="existing_request.status == 'pending'">⏳ Request menunggu konfirmasi</t>
                                        <t t-elif="existing_request.status == 'approved'">✅ Terhubung dengan mentor</t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <t t-if="alumni.ketersediaan == 'available' and alumni.slot_mentoring > 0">
                                        <button onclick="document.getElementById('modal-request').style.display='flex'" class="mtz-btn-primary mtz-btn-fit" style="margin-top: 20px;">📩 Ajukan Mentoring</button>
                                    </t>
                                    <t t-else="">
                                        <div class="mtz-alert-warning" style="margin-top: 16px;">Mentor sedang tidak tersedia</div>
                                    </t>
                                </t>
                            </t>
                        </div>

                        <!-- Right content -->
                        <div class="mtz-panel">
                            <div class="mtz-panel-header compact"><div><h2>Tentang Mentor</h2></div></div>
                            <p class="mtz-profil-text" t-esc="alumni.deskripsi or 'Belum ada deskripsi.'"/>

                            <div class="mtz-form-section">
                                <h2>Keahlian</h2>
                                <div class="mtz-badge-list">
                                    <t t-foreach="alumni.skill_ids" t-as="skill">
                                        <span class="mtz-badge-skill" t-esc="skill.name"/>
                                    </t>
                                    <t t-if="not alumni.skill_ids"><span class="mtz-text-muted">Belum ada skill terdaftar</span></t>
                                </div>
                            </div>

                            <div class="mtz-form-section">
                                <h2>Pengalaman</h2>
                                <t t-foreach="alumni.experience_ids" t-as="exp">
                                    <div style="margin-bottom: 16px;">
                                        <b t-esc="exp.posisi or '-'"/> di <span t-esc="exp.perusahaan or '-'"/>
                                        <p class="mtz-text-muted" t-esc="exp.deskripsi or ''"/>
                                    </div>
                                </t>
                                <t t-if="not alumni.experience_ids"><p class="mtz-text-muted">Belum ada pengalaman terdaftar</p></t>
                            </div>

                            <div class="mtz-form-section">
                                <h2>Ulasan Mentee</h2>
                                <t t-foreach="feedbacks" t-as="fb">
                                    <div style="padding: 12px 0; border-bottom: 1px solid var(--mtz-line);">
                                        <b t-esc="fb.mahasiswa_id.name or 'Anonim'"/> ★ <t t-esc="fb.rating"/>
                                        <p t-esc="fb.komentar or ''"/>
                                    </div>
                                </t>
                                <t t-if="not feedbacks"><p class="mtz-text-muted">Belum ada ulasan</p></t>
                            </div>
                        </div>
                    </div>
                </section>
            </main>

            <!-- Modal Request -->
            <div id="modal-request" class="mtz-modal-overlay" style="display:none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000;">
                <div class="mtz-panel" style="max-width: 500px; width: 90%;">
                    <div class="mtz-panel-header"><div><h2>📩 Ajukan Mentoring</h2><p>Kirim permintaan ke <b t-esc="alumni.name"/></p></div></div>
                    <form t-attf-action="/mentorize/mentor/request/#{alumni.id}" method="post" class="mtz-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mtz-form-group">
                            <label>Topik Mentoring *</label>
                            <input type="text" name="topik" placeholder="Contoh: Tips masuk dunia kerja, Review CV" required="1"/>
                        </div>
                        <div class="mtz-form-group">
                            <label>Deskripsi (opsional)</label>
                            <textarea name="deskripsi" rows="4" placeholder="Ceritakan lebih detail..."></textarea>
                        </div>
                        <div class="mtz-form-actions">
                            <button type="button" onclick="document.getElementById('modal-request').style.display='none'" class="mtz-btn-secondary">Batal</button>
                            <button type="submit" class="mtz-btn-primary">Kirim Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <!-- ======================== REKOMENDASI MENTOR ======================== -->
    <template id="page_rekomendasi_mentor" name="Rekomendasi Mentor">
        <t t-call="web.layout">
            <t t-set="head">
                <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
            </t>
            <main class="mtz-app-page">
                <nav class="mtz-app-nav mtz-animate-down">
                    <a href="/mentorize/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
                    <div class="mtz-app-menu">
                        <a href="/mentorize/dashboard">Dashboard</a>
                        <a href="/mentorize/mentor">Cari Mentor</a>
                        <a href="/mentorize/recommendations" class="active">Rekomendasi</a>
                        <a href="/mentorize/history">Riwayat</a>
                        <a href="/mentorize/profile">Profil</a>
                    </div>
                    <div class="mtz-user-chip">
                        <span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></span>
                        <span><b t-esc="user.name"/><small>Mahasiswa</small></span>
                    </div>
                </nav>

                <section class="mtz-dashboard-shell">
                    <div class="mtz-panel mtz-animate-up">
                        <div class="mtz-panel-header">
                            <div><h2>✨ Rekomendasi Mentor untuk Kamu</h2><p>Berdasarkan skill dan minat yang kamu miliki</p></div>
                        </div>
                        <div class="mtz-mentor-grid">
                            <t t-foreach="matchmakings" t-as="match">
                                <article class="mtz-mentor-card">
                                    <div class="mtz-state success" style="margin-bottom: 12px;">⭐ Top Match</div>
                                    <div class="mtz-mentor-top">
                                        <span class="mtz-avatar-circle"><t t-esc="match.alumni_id.name and match.alumni_id.name[:1].upper() or 'A'"/></span>
                                        <div><h3 t-esc="match.alumni_id.name"/><p t-esc="match.alumni_id.pekerjaan or 'Alumni Mentor'"/></div>
                                        <span class="mtz-rating">★ <t t-esc="'%.1f' % match.alumni_id.rating"/></span>
                                    </div>
                                    <div class="mtz-mini-stats" style="margin: 8px 0;">
                                        <span>🎯 Skor: <b><t t-esc="'%.1f' % match.score"/></b></span>
                                        <span><t t-esc="match.skill_match"/> skill cocok</span>
                                    </div>
                                    <div class="mtz-badge-list">
                                        <t t-foreach="match.alumni_id.skill_ids[:3]" t-as="skill">
                                            <span class="mtz-badge-skill" t-esc="skill.name"/>
                                        </t>
                                    </div>
                                    <a t-attf-href="/mentorize/mentor/#{match.alumni_id.id}" class="mtz-btn-primary mtz-btn-fit" style="margin-top: 16px;">Lihat Profil</a>
                                </article>
                            </t>
                            <t t-if="not matchmakings">
                                <div class="mtz-empty-state full">
                                    <b>🤔 Belum ada rekomendasi</b>
                                    <p>Lengkapi profil skill dan minat kamu agar sistem bisa menemukan mentor yang cocok</p>
                                    <a href="/mentorize/profile/edit" class="mtz-btn-primary">Lengkapi Profil</a>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </main>
        </t>
    </template>

    <!-- ======================== RIWAYAT MAHASISWA ======================== -->
    <template id="page_riwayat_mahasiswa" name="Riwayat Mentoring Mahasiswa">
        <t t-call="web.layout">
            <t t-set="head">
                <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
            </t>
            <main class="mtz-app-page">
                <nav class="mtz-app-nav mtz-animate-down">
                    <a href="/mentorize/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
                    <div class="mtz-app-menu">
                        <a href="/mentorize/dashboard">Dashboard</a>
                        <a href="/mentorize/mentor">Cari Mentor</a>
                        <a href="/mentorize/recommendations">Rekomendasi</a>
                        <a href="/mentorize/history" class="active">Riwayat</a>
                        <a href="/mentorize/profile">Profil</a>
                    </div>
                    <div class="mtz-user-chip">
                        <span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></span>
                        <span><b t-esc="user.name"/><small>Mahasiswa</small></span>
                    </div>
                </nav>

                <section class="mtz-dashboard-shell">
                    <div class="mtz-panel mtz-animate-up">
                        <div class="mtz-panel-header">
                            <div><h2>📋 Riwayat Mentoring</h2><p>Semua request mentoring yang pernah kamu ajukan</p></div>
                            <a href="/mentorize/mentor" class="mtz-btn-primary">+ Cari Mentor Baru</a>
                        </div>
                        <t t-if="success">
                            <div class="mtz-alert-success">✅ Request mentoring berhasil dikirim! Tunggu konfirmasi dari mentor.</div>
                        </t>
                        <div class="mtz-request-list">
                            <t t-foreach="requests" t-as="req">
                                <div class="mtz-request-card">
                                    <div class="mtz-request-info">
                                        <span class="mtz-avatar-circle"><t t-esc="req.alumni_id.name and req.alumni_id.name[:1].upper() or 'A'"/></span>
                                        <div>
                                            <b t-esc="req.alumni_id.name"/>
                                            <small t-esc="req.topik"/>
                                            <p><t t-esc="req.tanggal_request.strftime('%d %b %Y') if req.tanggal_request else '-'"/></p>
                                        </div>
                                    </div>
                                    <div>
                                        <span t-attf-class="mtz-state #{req.status == 'pending' and 'info' or (req.status == 'approved' and 'success' or 'muted')}">
                                            <t t-if="req.status == 'pending'">⏳ Menunggu</t>
                                            <t t-elif="req.status == 'approved'">✅ Diterima</t>
                                            <t t-elif="req.status == 'rejected'">❌ Ditolak</t>
                                        </span>
                                        <a t-attf-href="/mentorize/mentor/#{req.alumni_id.id}" class="mtz-btn-small" style="margin-left: 12px;">Lihat Mentor</a>
                                    </div>
                                </div>
                            </t>
                            <t t-if="not requests">
                                <div class="mtz-empty-state">
                                    <b>📭 Belum ada riwayat mentoring</b>
                                    <p>Mulai dengan mencari mentor yang sesuai</p>
                                    <a href="/mentorize/mentor" class="mtz-btn-primary">Cari Mentor</a>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </main>
        </t>
    </template>

    <!-- ======================== RIWAYAT ALUMNI ======================== -->
    <template id="page_riwayat_alumni" name="Riwayat Mentoring Alumni">
        <t t-call="web.layout">
            <t t-set="head">
                <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
            </t>
            <main class="mtz-app-page">
                <nav class="mtz-app-nav mtz-animate-down">
                    <a href="/mentorize/alumni/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
                    <div class="mtz-app-menu">
                        <a href="/mentorize/alumni/dashboard">Dashboard</a>
                        <a href="/mentorize/alumni/history" class="active">Riwayat</a>
                        <a href="/mentorize/chat">Chat</a>
                    </div>
                    <div class="mtz-user-chip">
                        <span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'A'"/></span>
                        <span><b t-esc="user.name"/><small>Alumni</small></span>
                    </div>
                </nav>

                <section class="mtz-dashboard-shell">
                    <div class="mtz-panel mtz-animate-up">
                        <div class="mtz-panel-header"><div><h2>📋 Riwayat Mentoring</h2><p>Semua request mentoring yang masuk ke kamu</p></div></div>
                        <div class="mtz-request-list">
                            <t t-foreach="requests" t-as="req">
                                <div class="mtz-request-card">
                                    <div class="mtz-request-info">
                                        <span class="mtz-avatar-circle"><t t-esc="req.mahasiswa_id.name and req.mahasiswa_id.name[:1].upper() or 'M'"/></span>
                                        <div>
                                            <b t-esc="req.mahasiswa_id.name"/>
                                            <small t-esc="req.topik"/>
                                            <p><t t-esc="req.tanggal_request.strftime('%d %b %Y') if req.tanggal_request else '-'"/></p>
                                        </div>
                                    </div>
                                    <span t-attf-class="mtz-state #{req.status == 'pending' and 'info' or (req.status == 'approved' and 'success' or 'muted')}">
                                        <t t-if="req.status == 'pending'">⏳ Menunggu</t>
                                        <t t-elif="req.status == 'approved'">✅ Diterima</t>
                                        <t t-elif="req.status == 'rejected'">❌ Ditolak</t>
                                    </span>
                                </div>
                            </t>
                            <t t-if="not requests">
                                <div class="mtz-empty-state"><b>📭 Belum ada riwayat</b></div>
                            </t>
                        </div>
                    </div>
                </section>
            </main>
        </t>
    </template>
</odoo>