<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="page_sesi_mentoring_mahasiswa" name="Sesi Mentoring Mahasiswa">
        <t t-call="website.layout">
            <style>
                .mz-page {
                    background: #f5f8fb;
                    min-height: 100vh;
                    padding: 34px 0 60px;
                    font-family: Inter, Arial, sans-serif;
                }

                .mz-container {
                    max-width: 1080px;
                    margin: 0 auto;
                    padding: 0 18px;
                }

                .mz-hero {
                    background: linear-gradient(120deg, #132f55 0%, #0d4267 48%, #11b5a4 100%);
                    border-radius: 0 0 22px 22px;
                    padding: 34px 38px;
                    color: white;
                    box-shadow: 0 18px 38px rgba(11, 45, 82, .18);
                    margin-bottom: 26px;
                    display: flex;
                    justify-content: space-between;
                    gap: 20px;
                    align-items: center;
                }

                .mz-badge {
                    display: inline-flex;
                    align-items: center;
                    padding: 7px 15px;
                    border: 1px solid rgba(255,255,255,.35);
                    border-radius: 999px;
                    font-size: 13px;
                    font-weight: 700;
                    background: rgba(255,255,255,.12);
                    margin-bottom: 14px;
                }

                .mz-hero h1 {
                    margin: 0 0 8px;
                    font-size: 34px;
                    font-weight: 850;
                    letter-spacing: .2px;
                }

                .mz-hero p {
                    margin: 0;
                    color: rgba(255,255,255,.88);
                    font-size: 15px;
                }

                .mz-hero-action {
                    background: #26c7b9;
                    color: white;
                    text-decoration: none;
                    border-radius: 12px;
                    padding: 12px 18px;
                    font-weight: 850;
                    white-space: nowrap;
                    box-shadow: 0 12px 28px rgba(38,199,185,.25);
                }

                .mz-grid-main {
                    display: grid;
                    grid-template-columns: 1.3fr .9fr;
                    gap: 20px;
                    margin-bottom: 20px;
                }

                .mz-grid-three {
                    display: grid;
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                    gap: 20px;
                }

                .mz-card {
                    background: #fff;
                    border: 1px solid #e5edf4;
                    border-radius: 17px;
                    box-shadow: 0 12px 30px rgba(15, 42, 70, .07);
                    padding: 20px;
                }

                .mz-card-title {
                    font-size: 21px;
                    font-weight: 850;
                    color: #16304f;
                    margin: 0;
                }

                .mz-card-subtitle {
                    color: #8090a5;
                    font-size: 13px;
                    margin: 4px 0 18px;
                }

                .mz-session {
                    border: 1px solid #dbe7f0;
                    border-radius: 15px;
                    padding: 15px;
                    margin-bottom: 14px;
                    background: #fbfdff;
                }

                .mz-session-head {
                    display: flex;
                    justify-content: space-between;
                    gap: 12px;
                    align-items: flex-start;
                    margin-bottom: 10px;
                }

                .mz-name {
                    font-size: 15px;
                    font-weight: 800;
                    color: #172b49;
                    margin: 0;
                }

                .mz-meta {
                    font-size: 12px;
                    color: #718096;
                    margin: 2px 0 0;
                }

                .mz-status {
                    display: inline-flex;
                    align-items: center;
                    border-radius: 999px;
                    padding: 5px 10px;
                    font-size: 11px;
                    font-weight: 800;
                    white-space: nowrap;
                }

                .mz-status.scheduled {
                    background: #e8f5ff;
                    color: #1677b8;
                }

                .mz-status.completed {
                    background: #e9fbf2;
                    color: #14895a;
                }

                .mz-status.cancelled {
                    background: #fff0f0;
                    color: #c0392b;
                }

                .mz-status.rescheduled {
                    background: #fff7df;
                    color: #a96f00;
                }

                .mz-info {
                    display: grid;
                    gap: 7px;
                    margin: 12px 0 14px;
                    color: #506177;
                    font-size: 13px;
                }

                .mz-info strong {
                    color: #263b58;
                }

                .mz-actions {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 8px;
                    margin-top: 12px;
                }

                .mz-btn {
                    border: 0;
                    border-radius: 10px;
                    padding: 9px 12px;
                    font-weight: 800;
                    font-size: 12px;
                    text-decoration: none;
                    cursor: pointer;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                }

                .mz-btn-primary {
                    background: linear-gradient(90deg, #28c8bb, #099c91);
                    color: white;
                }

                .mz-btn-warning {
                    background: #fff5d9;
                    color: #a46b00;
                }

                .mz-btn-danger {
                    background: #ffe8e8;
                    color: #bf2d2d;
                }

                .mz-btn-soft {
                    background: #eef4f8;
                    color: #23405f;
                }

                .mz-form-group {
                    margin-bottom: 14px;
                }

                .mz-label {
                    display: block;
                    color: #253b57;
                    font-weight: 800;
                    font-size: 13px;
                    margin-bottom: 7px;
                }

                .mz-input,
                .mz-select,
                .mz-textarea {
                    width: 100%;
                    border: 1px solid #d7e3ec;
                    border-radius: 12px;
                    padding: 11px 12px;
                    color: #263b58;
                    background: #fbfdff;
                    outline: none;
                    font-size: 14px;
                }

                .mz-input:focus,
                .mz-select:focus,
                .mz-textarea:focus {
                    border-color: #20b8ac;
                    box-shadow: 0 0 0 3px rgba(32,184,172,.12);
                }

                .mz-textarea {
                    min-height: 90px;
                    resize: vertical;
                }

                .mz-submit {
                    width: 100%;
                    border: 0;
                    border-radius: 12px;
                    background: linear-gradient(90deg, #28c8bb, #099c91);
                    color: #fff;
                    font-weight: 850;
                    padding: 12px 16px;
                    cursor: pointer;
                    box-shadow: 0 12px 24px rgba(9,156,145,.18);
                }

                .mz-empty {
                    border: 1px dashed #b8c9dc;
                    background: #fbfdff;
                    border-radius: 14px;
                    color: #66758a;
                    text-align: center;
                    font-weight: 750;
                    padding: 24px 12px;
                    font-size: 14px;
                }

                .mz-form-mini {
                    display: none;
                    margin-top: 12px;
                    padding: 14px;
                    border-radius: 16px;
                    background: #f6f9fc;
                    border: 1px solid #e2ebf4;
                }

                .mz-form-mini input,
                .mz-form-mini textarea {
                    width: 100%;
                    border: 1px solid #d8e4ef;
                    border-radius: 12px;
                    padding: 10px 12px;
                    margin-bottom: 10px;
                    font-size: 13px;
                }

                .mz-toggle {
                    display: none;
                }

                .mz-toggle:checked + .mz-form-mini {
                    display: block;
                }

                @media (max-width: 900px) {
                    .mz-hero,
                    .mz-grid-main,
                    .mz-grid-three {
                        grid-template-columns: 1fr;
                    }

                    .mz-hero {
                        display: block;
                    }

                    .mz-hero-action {
                        display: inline-flex;
                        margin-top: 20px;
                    }

                    .mz-hero h1 {
                        font-size: 27px;
                    }
                }
            </style>

            <div class="mz-page">
                <div class="mz-container">

                    <!-- HERO -->
                    <section class="mz-hero">
                        <div>
                            <span class="mz-badge">Sesi Mentoring Mahasiswa</span>
                            <h1>Atur Jadwal Mentoringmu 👋</h1>
                            <p>
                                Lihat jadwal mentoring, ajukan sesi baru, pantau sesi berjalan,
                                dan cek riwayat mentoringmu.
                            </p>
                        </div>

                        <a href="#form-ajukan-jadwal" class="mz-hero-action">
                            Ajukan Jadwal
                        </a>
                    </section>

                    <div class="mz-grid-main">

                        <!-- JADWAL TERDEKAT -->
                        <section class="mz-card">
                            <h2 class="mz-card-title">Jadwal Terdekat</h2>
                            <p class="mz-card-subtitle">Sesi mentoring yang sudah dijadwalkan.</p>

                            <t t-if="upcoming_sessions">
                                <t t-foreach="upcoming_sessions[:5]" t-as="sesi">
                                    <div class="mz-session">
                                        <div class="mz-session-head">
                                            <div>
                                                <p class="mz-name">
                                                    <t t-esc="sesi.request_id.alumni_id.name"/>
                                                </p>
                                                <p class="mz-meta">
                                                    Mentor / Alumni
                                                </p>
                                            </div>

                                            <span t-attf-class="mz-status #{sesi.status}">
                                                <t t-if="sesi.status == 'scheduled'">Terjadwal</t>
                                                <t t-if="sesi.status == 'rescheduled'">Reschedule</t>
                                            </span>
                                        </div>

                                        <div class="mz-info">
                                            <div>
                                                📌 <strong>Topik:</strong>
                                                <t t-esc="sesi.request_id.topik"/>
                                            </div>

                                            <div>
                                                📅 <strong>Tanggal:</strong>
                                                <t t-esc="sesi.tanggal_mentoring"/>
                                            </div>

                                            <div>
                                                ⏱️ <strong>Durasi:</strong>
                                                <t t-esc="sesi.durasi"/> menit
                                            </div>

                                            <div>
                                                📍 <strong>Mode:</strong>
                                                <t t-esc="dict(sesi._fields['mode'].selection).get(sesi.mode)"/>
                                            </div>

                                            <div>
                                                🔗 <strong>Lokasi/Link:</strong>
                                                <t t-esc="sesi.lokasi_link or '-'"/>
                                            </div>
                                        </div>

                                        <div class="mz-actions">
                                            <a t-att-href="'/mentorize/chat/request/%s' % sesi.request_id.id"
                                               class="mz-btn mz-btn-soft">
                                                Buka Chat
                                            </a>

                                            <label t-att-for="'reschedule-mahasiswa-%s' % sesi.id"
                                                   class="mz-btn mz-btn-warning">
                                                Reschedule
                                            </label>

                                            <form t-att-action="'/mentorize/session/%s/cancel' % sesi.id"
                                                  method="post"
                                                  style="display:inline;">
                                                <input type="hidden"
                                                       name="csrf_token"
                                                       t-att-value="request.csrf_token()"/>

                                                <button type="submit" class="mz-btn mz-btn-danger">
                                                    Cancel
                                                </button>
                                            </form>
                                        </div>

                                        <!-- FORM RESCHEDULE -->
                                        <input class="mz-toggle"
                                               type="checkbox"
                                               t-att-id="'reschedule-mahasiswa-%s' % sesi.id"/>

                                        <form class="mz-form-mini"
                                              t-att-action="'/mentorize/session/%s/reschedule' % sesi.id"
                                              method="post">
                                            <input type="hidden"
                                                   name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>

                                            <input type="datetime-local"
                                                   name="tanggal_mentoring"
                                                   required="required"/>

                                            <textarea name="ringkasan_materi"
                                                      placeholder="Catatan atau alasan reschedule"></textarea>

                                            <button type="submit" class="mz-btn mz-btn-warning">
                                                Simpan Reschedule
                                            </button>
                                        </form>
                                    </div>
                                </t>
                            </t>

                            <t t-else="">
                                <div class="mz-empty">
                                    Belum ada jadwal sesi mendatang.
                                </div>
                            </t>
                        </section>

                        <!-- FORM AJUKAN JADWAL -->
                        <section class="mz-card" id="form-ajukan-jadwal">
                            <h2 class="mz-card-title">Ajukan Jadwal</h2>
                            <p class="mz-card-subtitle">
                                Pilih request yang sudah disetujui, lalu ajukan jadwal sesi mentoring.
                            </p>

                            <form action="/mentorize/mahasiswa/sesi/ajukan"
                                  method="post"
                                  class="mz-form">

                                <input type="hidden"
                                       name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <div class="mz-form-group">
                                    <label class="mz-label">Request Mentoring</label>
                                    <select name="request_id" class="mz-select" required="required">
                                        <option value="">Pilih request mentoring</option>

                                        <t t-foreach="approved_requests" t-as="req">
                                            <option t-att-value="req.id">
                                                <t t-esc="req.alumni_id.name"/>
                                                <t t-if="req.topik">
                                                    -
                                                    <t t-esc="req.topik"/>
                                                </t>
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <div class="mz-form-group">
                                    <label class="mz-label">Tanggal &amp; Jam Sesi</label>
                                    <input type="datetime-local"
                                           name="tanggal_mentoring"
                                           class="mz-input"
                                           required="required"/>
                                </div>

                                <div class="mz-form-group">
                                    <label class="mz-label">Durasi</label>
                                    <select name="durasi" class="mz-select" required="required">
                                        <option value="30">30 menit</option>
                                        <option value="60" selected="selected">60 menit</option>
                                        <option value="90">90 menit</option>
                                        <option value="120">120 menit</option>
                                    </select>
                                </div>

                                <div class="mz-form-group">
                                    <label class="mz-label">Mode Mentoring</label>
                                    <select name="mode" class="mz-select" required="required">
                                        <option value="online">Online</option>
                                        <option value="offline">Offline</option>
                                    </select>
                                </div>

                                <div class="mz-form-group">
                                    <label class="mz-label">Lokasi / Link Meeting</label>
                                    <input type="text"
                                           name="lokasi_link"
                                           class="mz-input"
                                           placeholder="Contoh: Google Meet / Ruang Diskusi Kampus"/>
                                </div>

                                <div class="mz-form-group">
                                    <label class="mz-label">Catatan Materi</label>
                                    <textarea name="ringkasan_materi"
                                              class="mz-textarea"
                                              placeholder="Tulis topik atau materi yang ingin dibahas..."></textarea>
                                </div>

                                <button type="submit" class="mz-submit">
                                    Kirim Pengajuan Jadwal
                                </button>
                            </form>
                        </section>

                    </div>

                    <!-- BAWAH: SESI BERJALAN + RIWAYAT -->
                    <div class="mz-grid-three">

                        <!-- MENTORING AKTIF -->
                        <section class="mz-card">
                            <h2 class="mz-card-title">Mentoring Aktif</h2>
                            <p class="mz-card-subtitle">Request yang sudah disetujui.</p>

                            <t t-if="approved_requests">
                                <t t-foreach="approved_requests[:4]" t-as="req">
                                    <div class="mz-session">
                                        <div class="mz-session-head">
                                            <div>
                                                <p class="mz-name">
                                                    <t t-esc="req.alumni_id.name"/>
                                                </p>
                                                <p class="mz-meta">Alumni Mentor</p>
                                            </div>
                                            <span class="mz-status scheduled">Aktif</span>
                                        </div>

                                        <div class="mz-info">
                                            <div>
                                                📌 <strong>Topik:</strong>
                                                <t t-esc="req.topik"/>
                                            </div>
                                            <div>
                                                📝 <strong>Deskripsi:</strong>
                                                <t t-esc="req.deskripsi or '-'"/>
                                            </div>
                                        </div>

                                        <div class="mz-actions">
                                            <a t-att-href="'/mentorize/chat/request/%s' % req.id"
                                               class="mz-btn mz-btn-soft">
                                                Buka Chat
                                            </a>

                                            <a href="#form-ajukan-jadwal"
                                               class="mz-btn mz-btn-primary">
                                                Ajukan Jadwal
                                            </a>
                                        </div>
                                    </div>
                                </t>
                            </t>

                            <t t-else="">
                                <div class="mz-empty">
                                    Belum ada mentoring aktif.
                                </div>
                            </t>
                        </section>

                        <!-- SESI BERJALAN -->
                        <section class="mz-card">
                            <h2 class="mz-card-title">Sesi Berjalan</h2>
                            <p class="mz-card-subtitle">Sesi mentoring yang sedang aktif.</p>

                            <t t-if="active_sessions">
                                <t t-foreach="active_sessions[:4]" t-as="sesi">
                                    <div class="mz-session">
                                        <p class="mz-name">
                                            <t t-esc="sesi.request_id.alumni_id.name"/>
                                        </p>

                                        <div class="mz-info">
                                            <div>
                                                📌 <strong>Topik:</strong>
                                                <t t-esc="sesi.request_id.topik"/>
                                            </div>

                                            <div>
                                                📅 <strong>Jadwal:</strong>
                                                <t t-esc="sesi.tanggal_mentoring"/>
                                            </div>

                                            <div>
                                                📍 <strong>Tempat:</strong>
                                                <t t-esc="sesi.lokasi_link or '-'"/>
                                            </div>
                                        </div>

                                        <div class="mz-actions">
                                            <form t-att-action="'/mentorize/session/%s/complete' % sesi.id"
                                                method="post"
                                                style="display:inline;">
                                                <input type="hidden"
                                                    name="csrf_token"
                                                    t-att-value="request.csrf_token()"/>

                                                <button type="submit" class="mz-btn mz-btn-primary">
                                                    Konfirmasi Selesai
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </t>
                            </t>

                            <t t-else="">
                                <div class="mz-empty">
                                    Belum ada sesi berjalan.
                                </div>
                            </t>
                        </section>

                        <!-- RIWAYAT -->
                        <section class="mz-card">
                            <h2 class="mz-card-title">Riwayat Mentoring</h2>
                            <p class="mz-card-subtitle">Sesi terakhir yang tercatat.</p>

                            <t t-if="history_sessions">
                                <t t-foreach="history_sessions[:5]" t-as="sesi">
                                    <div class="mz-session">
                                        <div class="mz-session-head">
                                            <div>
                                                <p class="mz-name">
                                                    <t t-esc="sesi.request_id.alumni_id.name"/>
                                                </p>
                                                <p class="mz-meta">
                                                    <t t-esc="sesi.tanggal_mentoring"/>
                                                </p>
                                            </div>

                                            <span t-attf-class="mz-status #{sesi.status}">
                                                <t t-if="sesi.status == 'completed'">Selesai</t>
                                                <t t-if="sesi.status == 'cancelled'">Dibatalkan</t>
                                                <t t-if="sesi.status == 'rescheduled'">Reschedule</t>
                                            </span>
                                        </div>

                                        <div class="mz-info">
                                            <div>
                                                📌 <strong>Topik:</strong>
                                                <t t-esc="sesi.request_id.topik"/>
                                            </div>

                                            <div t-if="sesi.ringkasan_materi">
                                                📝 <strong>Ringkasan:</strong>
                                                <t t-esc="sesi.ringkasan_materi"/>
                                            </div>
                                        </div>

                                        <div class="mz-actions" t-if="sesi.status == 'completed'">
                                            <a t-att-href="'/mentorize/feedback/%s' % sesi.id"
                                               class="mz-btn mz-btn-soft">
                                                Beri Feedback
                                            </a>
                                        </div>
                                    </div>
                                </t>
                            </t>

                            <t t-else="">
                                <div class="mz-empty">
                                    Belum ada riwayat mentoring.
                                </div>
                            </t>
                        </section>

                    </div>

                </div>
            </div>
        </t>
    </template>
</odoo>