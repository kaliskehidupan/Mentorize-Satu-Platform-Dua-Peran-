<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="page_mentors" name="Cari Mentor Mentorize">
    <t t-call="mentorize.app_layout">
      <section class="mtz-hero-banner mtz-page-hero mtz-animate-up">
        <div>
          <span class="mtz-kicker">Cari Mentor</span>
          <h1>Mentor yang cocok untukmu</h1>
          <p>Temukan alumni terbaik berdasarkan minat, skill, tujuan karir, availability, dan rating mentor.</p>
        </div>
        <a class="mtz-btn magic large" href="/mentors?match=1">🪄 Cari Mentor Paling Cocok</a>
      </section>
      <t t-if="error"><div class="mtz-alert error" t-esc="error"/></t>
      <t t-if="success"><div class="mtz-alert success">Request mentoring berhasil dikirim.</div></t>
      <t t-if="match_active"><div class="mtz-alert success">✨ Matchmaking aktif. Mentor diurutkan dari skor kecocokan tertinggi.</div></t>
      <form action="/mentors" method="get" class="mtz-searchbar mtz-match-search">
        <input type="text" name="q" t-att-value="q" placeholder="Cari nama, pekerjaan, skill, atau bidang..."/>
        <button class="mtz-btn primary" type="submit">Cari</button>
      </form>
      <div class="mtz-mentor-grid">
        <t t-if="mentors">
          <t t-foreach="mentors" t-as="mentor">
            <div class="mtz-mentor-card match-card">
              <div class="mtz-match-topline">
                <img t-att-src="'/web/image/res.partner/%s/image_128' % mentor.user_id.partner_id.id"/>
                <div class="mtz-match-score-badge">
                  <span>🪄 <t t-esc="match_scores.get(mentor.id, 0)"/>%</span>
                  <small t-esc="match_labels.get(mentor.id, 'Cocok')"/>
                </div>
              </div>
              <h3 t-esc="mentor.name"/>
              <p t-esc="mentor.pekerjaan or 'Alumni Mentor'"/>
              <small t-esc="mentor.tempat_bekerja or 'Instansi belum diisi'"/>
              <div class="mtz-match-meter"><b t-attf-style="width:#{match_scores.get(mentor.id, 0)}%"></b></div>
              <div class="mtz-match-reasons">
                <t t-foreach="match_reasons.get(mentor.id, [])[:2]" t-as="reason"><span t-esc="reason"/></t>
              </div>
              <div class="mtz-tags"><t t-foreach="mentor.minat_ids[:3]" t-as="minat"><span t-esc="minat.name"/></t><t t-foreach="mentor.skill_ids[:3]" t-as="skill"><span t-esc="skill.name"/></t></div>
              <div class="mtz-mentor-meta"><span>⭐ <t t-esc="mentor.rating"/></span><span t-esc="'Tersedia' if mentor.availability == 'available' else ('Sibuk' if mentor.availability == 'busy' else 'Offline')"/></div>
              <button class="mtz-btn primary full" data-mtz-open-request="1" t-att-data-mentor-id="mentor.id" t-att-data-mentor-name="mentor.name">Ajukan Mentoring</button>
            </div>
          </t>
        </t>
        <t t-else=""><div class="mtz-empty-state">Belum ada mentor yang cocok dengan pencarianmu.</div></t>
      </div>
      <div class="mtz-modal-backdrop" id="mtz-request-modal">
        <div class="mtz-modal-card">
          <button type="button" class="mtz-modal-close" data-mtz-close-modal="1">×</button>
          <h2>Ajukan Mentoring</h2>
          <form action="/mentoring/request" method="post" class="mtz-form">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <input type="hidden" name="alumni_id" id="mtz-request-mentor-id"/>
            <label>Mentor<input type="text" id="mtz-request-mentor-name" readonly="readonly"/></label>
            <label>Topik Mentoring<input type="text" name="topik" required="required"/></label>
            <label>Tanggal &amp; Jam<input type="datetime-local" name="requested_datetime" t-att-min="today_min" t-att-max="max_datetime" required="required"/></label>
            <label>Catatan<textarea name="deskripsi" rows="4"></textarea></label>
            <button class="mtz-btn primary full" type="submit">Kirim Request</button>
          </form>
        </div>
      </div>
    </t>
  </template>
</odoo>
