<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
<template id="page_forgot_password" name="Mentorize Forgot Password">
  <t t-call="web.layout">
    <t t-set="head">
      <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
    </t>

    <main class="mtz-auth-page">
      <section class="mtz-auth-visual mtz-animate-left">
        <div class="mtz-auth-visual-inner">
          <img src="/mentorize/static/src/img/mentorize-illustration.svg" alt="Mentorize"/>
          <h2>Satu Platform, Dua Peran</h2>
          <p>Masukkan email akun Anda agar sistem dapat mengirim tautan pengaturan ulang kata sandi.</p>
        </div>
      </section>

      <section class="mtz-auth-panel mtz-animate-right">
        <div class="mtz-auth-card mtz-auth-card-small">
          <a class="mtz-logo" href="/">
            <span class="mtz-logo-circle">M</span>
            <span>Mentorize</span>
          </a>
          <h1>Lupa Password</h1>
          <p class="mtz-subtitle">Masukkan email Anda agar kami dapat mengirimkan tautan pengaturan ulang kata sandi kepada Anda.</p>

          <t t-if="success">
            <div class="mtz-alert-success">Email reset password telah dikirim. Silakan cek inbox Anda.</div>
          </t>
          <t t-if="error">
            <div class="mtz-alert-error"><t t-esc="error"/></div>
          </t>

          <form action="/forgot-password/submit" method="post" class="mtz-form mtz-loading-form">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <div class="mtz-form-group">
              <label>Email</label>
              <input type="email" name="email" placeholder="nama@email.com" required="1" autocomplete="email"/>
            </div>
            <button type="submit" class="mtz-btn-primary">Kirim Email</button>
          </form>

          <p class="mtz-register-link"><a href="/login">Kembali ke halaman login</a></p>
        </div>
      </section>
    </main>
  </t>
</template>
</data>
</odoo>
