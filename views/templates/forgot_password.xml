<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
<template id="page_forgot_password" name="Mentorize Forgot Password">
  <t t-call="web.layout">
    <t t-set="head">
      <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
    </t>
    <div class="mtz-login-page">
      <div class="mtz-left">
        <div class="mtz-illust-placeholder"></div>
        <h2>Satu Platform, Dua Peran</h2>
        <p>Masuk sebagai mahasiswa atau alumni untuk melanjutkan mentoring dan pengembangan karier Anda.</p>
      </div>
      <div class="mtz-right">
        <div class="mtz-logo">
          <div class="mtz-logo-circle">M</div>
          <span>Mentorize</span>
        </div>
        <h1>Lupa Password</h1>
        <p class="mtz-subtitle">Masukkan email Anda agar kami dapat mengirimkan tautan pengaturan ulang kata sandi kepada Anda.</p>

        <t t-if="success">
          <div class="mtz-alert-success">
            Email reset password telah dikirim! Silakan cek inbox Anda.
          </div>
        </t>
        <t t-if="error">
          <div class="mtz-alert-error">
            <t t-esc="error"/>
          </div>
        </t>

        <form action="/mentorize/forgot-password/submit" method="post">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <div class="mtz-form-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="nama@email.com" required="1"/>
          </div>
          <button type="submit" class="mtz-btn-primary">Kirim Email</button>
        </form>

        <p class="mtz-register-link">
          <a href="/mentorize/login">Kembali ke halaman login</a>
        </p>
      </div>
    </div>
  </t>
</template>
</data>
</odoo>