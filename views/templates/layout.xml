<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="app_layout" name="Mentorize App Layout">
    <html>
      <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>Mentorize</title>
        <link rel="stylesheet" type="text/css" href="/mentorize/static/src/css/mentorize.css"/>
      </head>
      <body class="mtz-body">
        <t t-if="is_admin_page">
          <div class="mtz-admin-shell">
            <aside class="mtz-admin-sidebar mtz-animate-left">
              <a class="mtz-admin-brand" href="/admin/dashboard">
                <img src="/mentorize/static/src/img/logo_mentorize.jpeg" alt="Mentorize"/>
                <div>
                  <strong>Mentorize</strong>
                  <span>Panel Admin</span>
                </div>
              </a>

              <div class="mtz-admin-side-section">
                <small>Ringkasan</small>
                <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/admin/dashboard"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 19h14v2H5a2 2 0 0 1-2-2V5h2v14Zm3-2V9h3v8H8Zm5 0V4h3v13h-3Zm5 0v-6h3v6h-3Z"/></svg></span> Beranda</a>
              </div>

              <div class="mtz-admin-side-section">
                <small>Manajemen Pengguna</small>
                <a t-att-class="'active' if active_menu == 'users' else ''" href="/admin/users"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 11a4 4 0 1 0-3.46-6A5 5 0 0 1 16 11ZM8 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm0 2c-3.31 0-6 1.79-6 4v2h12v-2c0-2.21-2.69-4-6-4Zm8-.5c-.74 0-1.44.1-2.08.29A5.62 5.62 0 0 1 16 18v2h6v-2c0-2.49-2.69-4.5-6-4.5Z"/></svg></span> Kelola Pengguna</a>
                <a t-att-class="'active' if active_menu == 'skills' else ''" href="/admin/skills"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7.5 12 3l8 4.5-8 4.5-8-4.5Zm0 4L12 16l8-4.5v3L12 19 4 14.5v-3Zm0 6L12 22l8-4.5V20l-8 4.5L4 20v-2.5Z"/></svg></span> Minat &amp; Skill</a>
              </div>

              <div class="mtz-admin-side-section">
                <small>Mentoring</small>
                <a t-att-class="'active' if active_menu == 'mentoring' else ''" href="/admin/mentoring"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.9 12a5 5 0 0 1 5-5h4v2h-4a3 3 0 0 0 0 6h4v2h-4a5 5 0 0 1-5-5Zm6 1v-2h4v2h-4Zm1-6h4a5 5 0 0 1 0 10h-4v-2h4a3 3 0 0 0 0-6h-4V7Z"/></svg></span> Pantau Mentoring</a>
                <a t-att-class="'active' if active_menu == 'feedback' else ''" href="/admin/feedback"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2 2.9 6.26 6.85.82-5.05 4.7 1.34 6.77L12 17.16l-6.04 3.39 1.34-6.77-5.05-4.7 6.85-.82L12 2Z"/></svg></span> Umpan Balik &amp; Ulasan</a>
              </div>

              <div class="mtz-admin-side-section">
                <small>Moderasi</small>
                <a t-att-class="'active' if active_menu == 'reports' else ''" href="/admin/reports"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 21V4h9l.5 2H21v10h-8.5l-.5-2H7v7H5Z"/></svg></span> Laporan</a>
                <a t-att-class="'active' if active_menu == 'activities' else ''" href="/admin/activities"><span class="mtz-admin-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20Zm1-10.4V6h-2v7l5 3 1-1.73-4-2.67Z"/></svg></span> Aktivitas Sistem</a>
              </div>

              <div class="mtz-admin-side-footer">
                <button type="button" class="mtz-admin-logout" data-mtz-open-logout="1">Keluar</button>
              </div>
            </aside>

            <main class="mtz-admin-workspace">
              <header class="mtz-admin-topbar mtz-animate-down">
                <div>
                  <span class="mtz-admin-eyebrow">Admin Mentorize</span>
                  <h2>
                    <t t-if="active_menu == 'dashboard'">Beranda Monitoring</t>
                    <t t-elif="active_menu == 'users'">Kelola Pengguna</t>
                    <t t-elif="active_menu == 'skills'">Minat &amp; Skill</t>
                    <t t-elif="active_menu == 'settings'">Pengaturan Admin</t>
                    <t t-elif="active_menu == 'mentoring'">Pantau Mentoring</t>
                    <t t-elif="active_menu == 'feedback'">Umpan Balik &amp; Ulasan</t>
                    <t t-elif="active_menu == 'reports'">Laporan &amp; Moderasi</t>
                    <t t-elif="active_menu == 'activities'">Aktivitas Sistem</t>
                    <t t-else="">Panel Admin</t>
                  </h2>
                </div>
                <div class="mtz-top-actions">
                  <div class="mtz-notif-wrap">
                    <button type="button" class="mtz-icon-btn" data-mtz-toggle="notifications" aria-label="Notifikasi">
                      <svg class="mtz-ui-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"/></svg>
                      <t t-if="unread_count"><em class="mtz-notif-badge" t-esc="unread_count"/></t>
                    </button>
                    <div class="mtz-dropdown mtz-notif-dropdown" id="mtz-notifications">
                      <div class="mtz-dropdown-head">
                        <strong>Notifikasi</strong>
                        <div class="mtz-notif-head-actions">
                          <button type="button" class="mtz-link-btn" data-mtz-read-notifications="1">Tandai dibaca</button>
                          <button type="button" class="mtz-link-btn mtz-link-btn-danger" data-mtz-delete-all-notifications="1">Hapus semua</button>
                        </div>
                      </div>
                      <div class="mtz-notif-scroll">
                        <t t-if="notifications">
                          <t t-foreach="notifications" t-as="notif">
                            <div t-att-class="'mtz-notif-item unread' if not notif.is_read else 'mtz-notif-item'" t-att-data-notif-id="notif.id">
                              <span class="mtz-notif-dot"></span>
                              <a t-att-href="notif.url or '#'" class="mtz-notif-content"><strong t-esc="notif.title"/><p t-esc="notif.message"/></a>
                              <button type="button" class="mtz-notif-delete-btn" t-att-data-notif-id="notif.id" aria-label="Hapus notifikasi">&#x2715;</button>
                            </div>
                          </t>
                        </t>
                        <t t-else=""><div class="mtz-empty-small">Belum ada notifikasi.</div></t>
                      </div>
                    </div>
                  </div>
                  <div class="mtz-user-wrap">
                    <button type="button" class="mtz-user-btn" data-mtz-toggle="user-menu"><img t-att-src="'/web/image/res.users/%s/image_128?unique=%s' % (user.id, user.write_date or user.id)" alt="Foto Profil"/><span t-esc="user.name"/></button>
                    <div class="mtz-dropdown mtz-user-dropdown" id="mtz-user-menu"><a href="/settings">Pengaturan</a><button type="button" data-mtz-open-logout="1">Keluar</button></div>
                  </div>
                </div>
              </header>

              <section class="mtz-admin-content">
                <t t-out="0"/>
              </section>
            </main>
          </div>
        </t>
        <t t-else="">
          <div class="mtz-app-shell">
            <nav class="mtz-topbar mtz-animate-down">
              <a class="mtz-brand" t-att-href="'/admin/dashboard' if role == 'admin' else ('/alumni/dashboard' if role == 'alumni' else '/dashboard')">
                <img src="/mentorize/static/src/img/logo_mentorize.jpeg" alt="Mentorize"/>
                <span>Mentorize</span>
              </a>

              <div class="mtz-navlinks">
                <t t-if="role == 'alumni'">
                  <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/alumni/dashboard">Beranda</a>
                  <a t-att-class="'active' if active_menu == 'chat' else ''" href="/chat">Pesan</a>
                  <a t-att-class="'active' if active_menu == 'profile' else ''" href="/alumni/profile/setup">Profil</a>
                  <a t-att-class="'active' if active_menu == 'reports' else ''" href="/reports">Laporan</a>
                  <a t-att-class="'active' if active_menu == 'history' else ''" href="/history">Riwayat</a>
                </t>
                <t t-elif="role == 'admin'">
                  <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/admin/dashboard">Beranda</a>
                  <a t-att-class="'active' if active_menu == 'users' else ''" href="/admin/users">Pengguna</a>
                  <a t-att-class="'active' if active_menu == 'skills' else ''" href="/admin/skills">Minat &amp; Skill</a>
                  <a t-att-class="'active' if active_menu == 'mentoring' else ''" href="/admin/mentoring">Mentoring</a>
                  <a t-att-class="'active' if active_menu == 'reports' else ''" href="/admin/reports">Laporan</a>
                  <a t-att-class="'active' if active_menu == 'activities' else ''" href="/admin/activities">Aktivitas</a>
                </t>
                <t t-else="">
                  <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/dashboard">Beranda</a>
                  <a t-att-class="'active' if active_menu == 'mentors' else ''" href="/mentors">Mentor</a>
                  <a t-att-class="'active' if active_menu == 'chat' else ''" href="/chat">Pesan</a>
                  <a t-att-class="'active' if active_menu == 'history' else ''" href="/history">Riwayat</a>
                  <a t-att-class="'active' if active_menu == 'profile' else ''" href="/profile">Profil</a>
                  <a t-att-class="'active' if active_menu == 'reports' else ''" href="/reports">Laporan</a>
                </t>
              </div>

              <div class="mtz-top-actions">
                <div class="mtz-notif-wrap">
                  <button type="button" class="mtz-icon-btn" data-mtz-toggle="notifications" aria-label="Notifikasi">
                    <svg class="mtz-ui-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22Zm7-6V11a7 7 0 0 0-5-6.7V3a2 2 0 1 0-4 0v1.3A7 7 0 0 0 5 11v5l-2 2v1h18v-1l-2-2Z"/></svg>
                    <t t-if="unread_count"><em class="mtz-notif-badge" t-esc="unread_count"/></t>
                  </button>
                  <div class="mtz-dropdown mtz-notif-dropdown" id="mtz-notifications">
                    <div class="mtz-dropdown-head">
                      <strong>Notifikasi</strong>
                      <div class="mtz-notif-head-actions">
                        <button type="button" class="mtz-link-btn" data-mtz-read-notifications="1">Tandai dibaca</button>
                        <button type="button" class="mtz-link-btn mtz-link-btn-danger" data-mtz-delete-all-notifications="1">Hapus semua</button>
                      </div>
                    </div>
                    <div class="mtz-notif-scroll">
                      <t t-if="notifications">
                        <t t-foreach="notifications" t-as="notif">
                          <div t-att-class="'mtz-notif-item unread' if not notif.is_read else 'mtz-notif-item'" t-att-data-notif-id="notif.id">
                            <span class="mtz-notif-dot"></span>
                            <a t-att-href="notif.url or '#'" class="mtz-notif-content"><strong t-esc="notif.title"/><p t-esc="notif.message"/></a>
                            <button type="button" class="mtz-notif-delete-btn" t-att-data-notif-id="notif.id" aria-label="Hapus notifikasi">&#x2715;</button>
                          </div>
                        </t>
                      </t>
                      <t t-else=""><div class="mtz-empty-small">Belum ada notifikasi.</div></t>
                    </div>
                  </div>
                </div>

                <div class="mtz-user-wrap">
                  <button type="button" class="mtz-user-btn" data-mtz-toggle="user-menu">
                    <img t-att-src="'/web/image/res.users/%s/image_128?unique=%s' % (user.id, user.write_date or user.id)" alt="Foto Profil"/>
                    <span class="mtz-profile-rating-inline" t-if="role == 'alumni' and user_rating">
                      <t t-esc="user.name"/>
                      <span class="mtz-star">&#11088;</span> <t t-esc="'%.1f' % user_rating"/>
                    </span>
                    <span t-else="" t-esc="user.name"/>
                  </button>
                  <div class="mtz-dropdown mtz-user-dropdown" id="mtz-user-menu"><a t-att-href="'/settings' if role == 'admin' else ('/alumni/profile/setup' if role == 'alumni' else '/profile')">Profil</a><a href="/settings">Pengaturan</a><button type="button" data-mtz-open-logout="1">Keluar</button></div>
                </div>
              </div>
            </nav>

            <t t-if="profile_incomplete">
              <div class="mtz-profile-incomplete-banner">
                <span class="mtz-profile-incomplete-icon">&#9888;</span>
                <span>Profil Anda belum lengkap. Beberapa fitur mungkin tidak tersedia.</span>
                <a t-att-href="'/alumni/profile/setup' if role == 'alumni' else '/profile'" class="mtz-profile-incomplete-link">Lengkapi Sekarang &#8594;</a>
              </div>
            </t>

            <main class="mtz-main-content">
              <t t-out="0"/>
            </main>
          </div>
        </t>

        <div class="mtz-modal-backdrop" id="mtz-logout-modal">
          <div class="mtz-confirm-modal">
            <div class="mtz-modal-icon"><svg class="mtz-modal-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M10 17v-3H3v-4h7V7l5 5-5 5Zm2-15h8a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2h-8v-2h8V4h-8V2Z"/></svg></div>
            <h3>Keluar dari Mentorize?</h3>
            <p>Pastikan semua perubahan sudah tersimpan sebelum logout.</p>
            <div class="mtz-modal-actions"><button type="button" class="mtz-btn ghost" data-mtz-close-logout="1">Batal</button><a class="mtz-btn danger" href="/logout/confirm">Ya, Keluar</a></div>
          </div>
        </div>

        <script type="text/javascript" src="/mentorize/static/src/js/mentorize.js"></script>
      </body>
    </html>
  </template>
</odoo>
