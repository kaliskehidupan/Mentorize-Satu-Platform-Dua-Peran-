<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="app_layout" name="Mentorize App Layout">
    <html>
      <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>Mentorize</title>
        <link rel="stylesheet" type="text/css" href="/mentorize/static/src/css/mentorize.css"/>
      </head>
      <body class="mtz-body">
        <div class="mtz-app-shell">
          <nav class="mtz-topbar mtz-animate-down">
            <a class="mtz-brand" t-att-href="'/alumni/dashboard' if role == 'alumni' else '/dashboard'">
              <img src="/mentorize/static/src/img/logo_mentorize.jpeg" alt="Mentorize"/>
              <span>Mentorize</span>
            </a>

            <div class="mtz-navlinks">
              <t t-if="role == 'alumni'">
                <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/alumni/dashboard">Dashboard</a>
                <a t-att-class="'active' if active_menu == 'chat' else ''" href="/chat">Chat</a>
                <a t-att-class="'active' if active_menu == 'profile' else ''" href="/alumni/profile/setup">Profil</a>
              </t>
              <t t-elif="role == 'admin'">
                <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/admin/dashboard">Dashboard</a>
              </t>
              <t t-else="">
                <a t-att-class="'active' if active_menu == 'dashboard' else ''" href="/dashboard">Dashboard</a>
                <a t-att-class="'active' if active_menu == 'mentors' else ''" href="/mentors">Mentor</a>
                <a t-att-class="'active' if active_menu == 'chat' else ''" href="/chat">Chat</a>
                <a t-att-class="'active' if active_menu == 'history' else ''" href="/history">Riwayat</a>
                <a t-att-class="'active' if active_menu == 'profile' else ''" href="/profile">Profil</a>
              </t>
            </div>

            <div class="mtz-top-actions">
              <div class="mtz-notif-wrap">
                <button type="button" class="mtz-icon-btn" data-mtz-toggle="notifications" aria-label="Notifikasi">
                  <span>🔔</span>
                  <t t-if="unread_count">
                    <em class="mtz-notif-badge" t-esc="unread_count"/>
                  </t>
                </button>
                <div class="mtz-dropdown mtz-notif-dropdown" id="mtz-notifications">
                  <div class="mtz-dropdown-head">
                    <strong>Notifikasi</strong>
                    <button type="button" class="mtz-link-btn" data-mtz-read-notifications="1">Tandai dibaca</button>
                  </div>
                  <t t-if="notifications">
                    <t t-foreach="notifications" t-as="notif">
                      <a t-att-href="notif.url or '#'" t-att-class="'mtz-notif-item unread' if not notif.is_read else 'mtz-notif-item'">
                        <span class="mtz-notif-dot"></span>
                        <div>
                          <strong t-esc="notif.title"/>
                          <p t-esc="notif.message"/>
                        </div>
                      </a>
                    </t>
                  </t>
                  <t t-else="">
                    <div class="mtz-empty-small">Belum ada notifikasi.</div>
                  </t>
                </div>
              </div>

              <div class="mtz-user-wrap">
                <button type="button" class="mtz-user-btn" data-mtz-toggle="user-menu">
                  <img t-att-src="'/web/image/res.users/%s/image_128' % user.id" alt="Foto Profil"/>
                  <span t-esc="user.name"/>
                </button>
                <div class="mtz-dropdown mtz-user-dropdown" id="mtz-user-menu">
                  <a t-att-href="'/alumni/profile/setup' if role == 'alumni' else '/profile'">Profil</a>
                  <a href="/settings">Setting</a>
                  <button type="button" data-mtz-open-logout="1">Logout</button>
                </div>
              </div>
            </div>
          </nav>

          <main class="mtz-main-content">
            <t t-out="0"/>
          </main>
        </div>

        <div class="mtz-modal-backdrop" id="mtz-logout-modal">
          <div class="mtz-confirm-modal">
            <div class="mtz-modal-icon">↪</div>
            <h3>Keluar dari Mentorize?</h3>
            <p>Pastikan semua perubahan sudah tersimpan sebelum logout.</p>
            <div class="mtz-modal-actions">
              <button type="button" class="mtz-btn ghost" data-mtz-close-logout="1">Batal</button>
              <a class="mtz-btn danger" href="/web/session/logout?redirect=/login">Ya, Logout</a>
            </div>
          </div>
        </div>

        <script type="text/javascript" src="/mentorize/static/src/js/mentorize.js"></script>
      </body>
    </html>
  </template>
</odoo>
