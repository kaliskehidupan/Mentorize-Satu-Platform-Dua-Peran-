<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="page_sesi_mentoring_alumni" name="Halaman Sesi Mentoring Alumni">
        <t t-call="website.layout">

            <style>
                .mz-page {
                    background: #f7fafc;
                    min-height: 100vh;
                    padding: 32px 0 60px;
                    font-family: 'Inter', Arial, sans-serif;
                }

                .mz-container {
                    max-width: 1180px;
                    margin: 0 auto;
                    padding: 0 20px;
                }

                .mz-hero {
                    background: linear-gradient(135deg, #112b4d 0%, #12385d 55%, #10b8aa 100%);
                    color: white;
                    padding: 36px;
                    border-radius: 0 0 26px 26px;
                    margin-bottom: 24px;
                    box-shadow: 0 20px 45px rgba(17, 43, 77, 0.18);
                }

                .mz-badge {
                    display: inline-block;
                    padding: 7px 15px;
                    border-radius: 999px;
                    background: rgba(255,255,255,0.16);
                    border: 1px solid rgba(255,255,255,0.25);
                    font-size: 13px;
                    font-weight: 700;
                    margin-bottom: 16px;
                }

                .mz-hero h1 {
                    font-size: 34px;
                    font-weight: 800;
                    margin: 0;
                }

                .mz-hero p {
                    margin-top: 10px;
                    color: rgba(255,255,255,0.82);
                    font-size: 15px;
                }

                .mz-grid {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: 18px;
                    margin-top: 22px;
                }

                .mz-card,
                .mentorize-card {
                    background: #ffffff;
                    border: 1px solid #e5edf5;
                    border-radius: 22px;
                    padding: 22px;
                    box-shadow: 0 12px 28px rgba(15, 40, 70, 0.06);
                }

                .mz-card-header,
                .mentorize-card-header {
                    margin-bottom: 18px;
                }

                .mz-card h2,
                .mentorize-card-header h3 {
                    font-size: 20px;
                    color: #10294a;
                    font-weight: 800;
                    margin: 0;
                }

                .mz-card p,
                .mentorize-card-header p {
                    margin: 4px 0 0;
                    color: #6b7c93;
                    font-size: 14px;
                }

                .mz-session-item {
                    border: 1px solid #e4edf7;
                    border-radius: 18px;
                    padding: 18px;
                    margin-bottom: 14px;
                    background: linear-gradient(180deg, #ffffff 0%, #f9fcff 100%);
                }

                .mz-session-title {
                    font-size: 16px;
                    font-weight: 800;
                    color: #10294a;
                    margin-bottom: 4px;
                }

                .mz-session-meta {
                    font-size: 13px;
                    color: #6b7c93;
                    margin-bottom: 8px;
                    line-height: 1.5;
                }

                .mz-session-meta strong {
                    color: #263b58;
                }

                .mz-state {
                    display: inline-flex;
                    align-items: center;
                    padding: 6px 12px;
                    border-radius: 999px;
                    font-size: 12px;
                    font-weight: 800;
                    margin-bottom: 12px;
                }

                .mz-state.scheduled {
                    background: #e9f5ff;
                    color: #1677c8;
                }

                .mz-state.rescheduled {
                    background: #fff7db;
                    color: #b77900;
                }

                .mz-state.completed {
                    background: #e9fbe9;
                    color: #1f9d55;
                }

                .mz-state.cancelled {
                    background: #ffecec;
                    color: #d64545;
                }

                .mz-actions {
                    display: flex;
                    gap: 8px;
                    flex-wrap: wrap;
                    margin-top: 12px;
                }

                .mz-btn {
                    border: none;
                    border-radius: 12px;
                    padding: 10px 14px;
                    font-size: 13px;
                    font-weight: 800;
                    cursor: pointer;
                    text-decoration: none;
                    display: inline-block;
                }

                .mz-btn-primary {
                    background: linear-gradient(135deg, #29c9bd, #08a99c);
                    color: white;
                }

                .mz-btn-dark {
                    background: #10294a;
                    color: white;
                }

                .mz-empty,
                .empty-session-box {
                    border: 1px dashed #cdd9e6;
                    border-radius: 18px;
                    padding: 26px;
                    text-align: center;
                    color: #6b7c93;
                    font-weight: 700;
                    background: #fbfdff;
                }

                .mentorize-session-list {
                    display: flex;
                    flex-direction: column;
                    gap: 14px;
                }

                .mentorize-session-item {
                    display: flex;
                    align-items: center;
                    gap: 16px;
                    padding: 16px;
                    border: 1px dashed #cbd5e1;
                    border-radius: 18px;
                    background: linear-gradient(135deg, #f8fafc, #ffffff);
                }

                .session-date-box {
                    min-width: 62px;
                    height: 68px;
                    border-radius: 18px;
                    background: linear-gradient(135deg, #0f2d4a, #14b8a6);
                    color: #ffffff;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                }

                .session-day {
                    font-size: 24px;
                    font-weight: 800;
                    line-height: 1;
                }

                .session-month {
                    font-size: 13px;
                    font-weight: 700;
                    text-transform: uppercase;
                    margin-top: 5px;
                }

                .session-info {
                    flex: 1;
                }

                .session-info h4 {
                    margin: 0 0 6px;
                    color: #10233f;
                    font-size: 17px;
                    font-weight: 800;
                }

                .session-info p {
                    margin: 3px 0;
                    color: #64748b;
                    font-size: 14px;
                }

                .session-topic {
                    color: #0f766e !important;
                    font-weight: 600;
                }

                .status-badge {
                    padding: 7px 12px;
                    border-radius: 999px;
                    font-size: 12px;
                    font-weight: 800;
                    white-space: nowrap;
                }

                .status-scheduled {
                    background: #dcfce7;
                    color: #166534;
                }

                .status-rescheduled {
                    background: #fef3c7;
                    color: #92400e;
                }

                @media (max-width: 900px) {
                    .mz-grid {
                        grid-template-columns: 1fr;
                    }

                    .mz-hero h1 {
                        font-size: 28px;
                    }

                    .mentorize-session-item {
                        align-items: flex-start;
                    }
                }
            </style>

            <div class="mz-page">
                <div class="mz-container">

                    <div class="mz-hero">
                        <div class="mz-badge">Sesi Mentoring Alumni</div>
                        <h1>Kelola Sesi Mentoringmu 👋</h1>
                        <p>
                            Lihat jadwal sesi, pantau mentoring aktif, atau tandai sesi sebagai selesai.
                        </p>
                    </div>

                    <div class="mz-grid">

                        <!-- JADWAL TERDEKAT -->
                        <div class="mentorize-card">
                            <div class="mentorize-card-header">
                                <h3>Jadwal Terdekat</h3>
                                <p>Sesi mentoring mendatang.</p>
                            </div>

                            <t t-if="upcoming_sessions">
                                <div class="mentorize-session-list">
                                    <t t-foreach="upcoming_sessions" t-as="session">
                                        <div class="mentorize-session-item">

                                            <div class="session-date-box">
                                                <span class="session-day" t-esc="session.tanggal_mentoring.strftime('%d') if session.tanggal_mentoring else '-'"/>
                                                <span class="session-month" t-esc="session.tanggal_mentoring.strftime('%b') if session.tanggal_mentoring else '-'"/>
                                            </div>

                                            <div class="session-info">
                                                <h4>
                                                    <t t-if="session.request_id.mahasiswa_id">
                                                        <t t-esc="session.request_id.mahasiswa_id.user_id.name"/>
                                                    </t>
                                                    <t t-else="">Mahasiswa Mentorize</t>
                                                </h4>

                                                <p>
                                                    <i class="fa fa-clock-o"></i>
                                                    <t t-esc="session.tanggal_mentoring.strftime('%H:%M') if session.tanggal_mentoring else '-'"/>
                                                    WIB •
                                                    <t t-esc="session.durasi"/>
                                                    menit
                                                </p>

                                                <p>
                                                    <i class="fa fa-map-marker"></i>
                                                    <t t-if="session.mode == 'online'">Online</t>
                                                    <t t-if="session.mode == 'offline'">Offline</t>
                                                    <t t-if="session.lokasi_link">
                                                        —
                                                        <t t-esc="session.lokasi_link"/>
                                                    </t>
                                                </p>

                                                <t t-if="session.ringkasan_materi">
                                                    <p class="session-topic">
                                                        <i class="fa fa-book"></i>
                                                        <t t-esc="session.ringkasan_materi"/>
                                                    </p>
                                                </t>
                                            </div>

                                            <div class="session-status">
                                                <span t-attf-class="status-badge status-#{session.status}">
                                                    <t t-if="session.status == 'scheduled'">Terjadwal</t>
                                                    <t t-elif="session.status == 'rescheduled'">Reschedule</t>
                                                    <t t-else="">
                                                        <t t-esc="session.status"/>
                                                    </t>
                                                </span>
                                            </div>

                                        </div>
                                    </t>
                                </div>
                            </t>

                            <t t-else="">
                                <div class="empty-session-box">
                                    Belum ada jadwal sesi mendatang.
                                </div>
                            </t>
                        </div>

                        <!-- SESI BERJALAN -->
                        <div class="mz-card">
                            <div class="mz-card-header">
                                <h2>Sesi Berjalan</h2>
                                <p>Mentoring yang sedang aktif.</p>
                            </div>

                            <t t-if="active_sessions">
                                <t t-foreach="active_sessions" t-as="session">
                                    <div class="mz-session-item">

                                        <div class="mz-session-title">
                                            <t t-esc="session.request_id.topik"/>
                                        </div>

                                        <div class="mz-session-meta">
                                            Mahasiswa:
                                            <strong>
                                                <t t-esc="session.request_id.mahasiswa_id.user_id.name"/>
                                            </strong>
                                        </div>

                                        <div class="mz-session-meta">
                                            Tanggal:
                                            <t t-esc="session.tanggal_mentoring"/>
                                        </div>

                                        <div class="mz-session-meta">
                                            Mode:
                                            <t t-esc="dict(session._fields['mode'].selection).get(session.mode)"/>
                                        </div>

                                        <span t-attf-class="mz-state #{session.status}">
                                            <t t-esc="dict(session._fields['status'].selection).get(session.status)"/>
                                        </span>

                                        <div class="mz-actions">
                                            <a t-if="session.request_id.room_chat_id"
                                               t-att-href="'/mentorize/chat/%s' % session.request_id.room_chat_id.id"
                                               class="mz-btn mz-btn-dark">
                                                Buka Chat
                                            </a>

                                            <form t-att-action="'/mentorize/session/%s/complete' % session.id" method="post">
                                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                <button type="submit" class="mz-btn mz-btn-primary">
                                                    Tandai Selesai
                                                </button>
                                            </form>
                                        </div>

                                    </div>
                                </t>
                            </t>

                            <t t-else="">
                                <div class="mz-empty">
                                    Belum ada sesi berjalan.
                                </div>
                            </t>
                        </div>

                        <!-- RIWAYAT MENTORING -->
                        <div class="mz-card">
                            <div class="mz-card-header">
                                <h2>Riwayat Mentoring</h2>
                                <p>Sesi selesai atau dibatalkan.</p>
                            </div>

                            <t t-if="history_sessions">
                                <t t-foreach="history_sessions" t-as="session">
                                    <div class="mz-session-item">

                                        <div class="mz-session-title">
                                            <t t-esc="session.request_id.topik"/>
                                        </div>

                                        <div class="mz-session-meta">
                                            Mahasiswa:
                                            <strong>
                                                <t t-esc="session.request_id.mahasiswa_id.user_id.name"/>
                                            </strong>
                                        </div>

                                        <div class="mz-session-meta">
                                            Tanggal:
                                            <t t-esc="session.tanggal_mentoring"/>
                                        </div>

                                        <div class="mz-session-meta">
                                            Ringkasan:
                                            <t t-esc="session.ringkasan_materi or '-'"/>
                                        </div>

                                        <span t-attf-class="mz-state #{session.status}">
                                            <t t-esc="dict(session._fields['status'].selection).get(session.status)"/>
                                        </span>

                                    </div>
                                </t>
                            </t>

                            <t t-else="">
                                <div class="mz-empty">
                                    Belum ada riwayat mentoring.
                                </div>
                            </t>
                        </div>

                    </div>
                </div>
            </div>

        </t>
    </template>

</odoo>