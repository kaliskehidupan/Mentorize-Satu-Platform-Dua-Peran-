<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="page_profile_mahasiswa" name="Profil Mahasiswa Mentorize">
    <t t-call="mentorize.app_layout">
      <section class="mtz-hero-banner mtz-page-hero mtz-animate-up">
        <div><span class="mtz-kicker"><t t-esc="'Setup Profil' if is_setup else 'Profil Mahasiswa'"/></span><h1>Lengkapi Profil Mentoring</h1><p>Data ini dipakai untuk merekomendasikan mentor yang paling sesuai.</p></div>
        <a href="/dashboard" class="mtz-btn soft">Ke Dashboard</a>
      </section>
      <t t-if="success"><div class="mtz-alert success">Profil berhasil diperbarui.</div></t>
      <t t-if="error"><div class="mtz-alert error" t-esc="error"/></t>
      <div class="mtz-profile-layout">
        <aside class="mtz-profile-card">
          <img class="mtz-profile-photo" t-att-src="'/web/image/res.partner/%s/image_1920' % user.partner_id.id"/>
          <h2 t-esc="user.name"/><p t-esc="user.email"/>
          <span t-att-class="'mtz-pill success' if mahasiswa.profile_complete else 'mtz-pill warning'"><t t-esc="'Profil Lengkap' if mahasiswa.profile_complete else 'Belum Lengkap'"/></span>
          <div class="mtz-profile-meta"><span>NIM</span><strong t-esc="mahasiswa.nim or '-'"/><span>Jurusan</span><strong t-esc="mahasiswa.jurusan or '-'"/><span>Semester</span><strong t-esc="mahasiswa.semester or '-'"/></div>
        </aside>
        <form action="/profile/update" method="post" enctype="multipart/form-data" class="mtz-card mtz-form profile-form">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <div class="mtz-card-head"><div><h2>Data Profil</h2><p>Upload foto profil dan lengkapi data akademik.</p></div></div>
          <label>Foto Profil<input type="file" name="photo" accept="image/*"/></label>
          <div class="mtz-form-grid two">
            <label>Nama Lengkap<input type="text" name="name" t-att-value="user.name" required="required"/></label>
            <label>NIM<input type="text" name="nim" t-att-value="mahasiswa.nim or user.nim or ''" required="required"/></label>
            <label>Jurusan / Prodi<input type="text" name="jurusan" t-att-value="mahasiswa.jurusan or user.jurusan or ''" required="required"/></label>
            <label>Semester<input type="number" name="semester" min="1" max="14" t-att-value="mahasiswa.semester or ''" required="required"/></label>
          </div>
          <label>Tujuan Karir<textarea name="tujuan_karir" rows="4" required="required" placeholder="Contoh: Saya ingin menjadi backend developer..."><t t-esc="mahasiswa.tujuan_karir or user.tujuan_karir or ''"/></textarea></label>
          <label>Bio Singkat<textarea name="bio" rows="3" placeholder="Ceritakan dirimu secara singkat..."><t t-esc="mahasiswa.bio or user.bio or ''"/></textarea></label>
          <div class="mtz-select-section"><h3>Minat</h3><div class="mtz-chip-grid"><t t-foreach="all_minat" t-as="minat"><label class="mtz-choice"><input type="checkbox" name="minat_ids" t-att-value="minat.id" t-att-checked="minat.id in selected_minat_ids and 'checked' or None"/><span t-esc="minat.name"/></label></t></div></div>
          <div class="mtz-select-section"><h3>Skill</h3><div class="mtz-chip-grid"><t t-foreach="all_skill" t-as="skill"><label class="mtz-choice"><input type="checkbox" name="skill_ids" t-att-value="skill.id" t-att-checked="skill.id in selected_skill_ids and 'checked' or None"/><span t-esc="skill.name"/></label></t></div></div>
          <button class="mtz-btn primary" type="submit">Simpan Profil</button>
        </form>
      </div>
    </t>
  </template>

  <template id="page_profile_alumni" name="Profil Alumni Mentorize">
    <t t-call="mentorize.app_layout">
      <section class="mtz-hero-banner mtz-page-hero mtz-animate-up"><div><span class="mtz-kicker">Profil Alumni</span><h1>Lengkapi Profil Mentor</h1><p>Data ini dipakai mahasiswa untuk mengenal bidang mentoring dan ketersediaanmu.</p></div></section>
      <t t-if="success"><div class="mtz-alert success">Profil berhasil diperbarui.</div></t>
      <t t-if="error"><div class="mtz-alert error" t-esc="error"/></t>
      <div class="mtz-profile-layout">
        <aside class="mtz-profile-card"><img class="mtz-profile-photo" t-att-src="'/web/image/res.partner/%s/image_1920' % user.partner_id.id"/><h2 t-esc="user.name"/><p t-esc="user.email"/><span t-att-class="'mtz-pill success' if alumni.profile_complete else 'mtz-pill warning'"><t t-esc="'Profil Lengkap' if alumni.profile_complete else 'Belum Lengkap'"/></span></aside>
        <form action="/alumni/profile/update" method="post" enctype="multipart/form-data" class="mtz-card mtz-form profile-form">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <label>Foto Profil<input type="file" name="photo" accept="image/*"/></label>
          <div class="mtz-form-grid two">
            <label>Nama Lengkap<input type="text" name="name" t-att-value="user.name" required="required"/></label>
            <label>KAPA / ID Alumni<input type="text" name="kapa" t-att-value="alumni.kapa or user.kapa or ''" required="required"/></label>
            <label>Pekerjaan<input type="text" name="pekerjaan" t-att-value="alumni.pekerjaan or ''" required="required"/></label>
            <label>Tempat Bekerja<input type="text" name="tempat_bekerja" t-att-value="alumni.tempat_bekerja or ''" required="required"/></label>
            <label>Tahun Lulus<input type="number" name="tahun_lulus" t-att-value="alumni.tahun_lulus or ''"/></label>
            <label>Slot Mentoring<input type="number" name="slot_mentoring" min="1" max="20" t-att-value="alumni.slot_mentoring or 3"/></label>
            <label>Ketersediaan<select name="availability"><option value="available" t-att-selected="alumni.availability == 'available' and 'selected' or None">Tersedia</option><option value="busy" t-att-selected="alumni.availability == 'busy' and 'selected' or None">Sibuk</option><option value="offline" t-att-selected="alumni.availability == 'offline' and 'selected' or None">Offline</option></select></label>
          </div>
          <label>Deskripsi / Pengalaman<textarea name="deskripsi" rows="4" required="required"><t t-esc="alumni.deskripsi or ''"/></textarea></label>
          <div class="mtz-select-section"><h3>Bidang Mentoring</h3><div class="mtz-chip-grid"><t t-foreach="all_minat" t-as="minat"><label class="mtz-choice"><input type="checkbox" name="minat_ids" t-att-value="minat.id" t-att-checked="minat.id in selected_minat_ids and 'checked' or None"/><span t-esc="minat.name"/></label></t></div></div>
          <div class="mtz-select-section"><h3>Skill</h3><div class="mtz-chip-grid"><t t-foreach="all_skill" t-as="skill"><label class="mtz-choice"><input type="checkbox" name="skill_ids" t-att-value="skill.id" t-att-checked="skill.id in selected_skill_ids and 'checked' or None"/><span t-esc="skill.name"/></label></t></div></div>
          <button class="mtz-btn primary" type="submit">Simpan Profil Mentor</button>
        </form>
      </div>
    </t>
  </template>
</odoo>
