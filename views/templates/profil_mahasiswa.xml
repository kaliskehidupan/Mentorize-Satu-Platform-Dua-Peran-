<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
<template id="page_profil_mahasiswa" name="Profil Mahasiswa">
  <t t-call="web.layout">
    <t t-set="head"><link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/></t>

    <main class="mtz-app-page">
      <nav class="mtz-app-nav mtz-animate-down">
        <a href="/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
        <div class="mtz-app-menu"><a href="/dashboard">Dashboard</a><a href="/mentors">Cari Mentor</a><a href="/profile" class="active">Profil</a><a href="/history">Riwayat</a><a href="/chat">Chat</a></div>
        <div class="mtz-user-chip"><span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></span><span><b t-esc="user.name"/><small>Mahasiswa</small></span></div>
      </nav>

      <section class="mtz-dashboard-shell">
        <t t-if="success"><div class="mtz-alert-success mtz-animate-up">Profil berhasil diperbarui.</div></t>
        <t t-if="not profil_lengkap"><div class="mtz-alert-warning mtz-animate-up">Profil kamu belum lengkap. Lengkapi data agar rekomendasi mentor lebih akurat.</div></t>

        <div class="mtz-profile-hero mtz-animate-up">
          <div class="mtz-profile-avatar"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></div>
          <div class="mtz-profile-title">
            <span class="mtz-kicker-light">Profil Mahasiswa</span>
            <h1 t-esc="user.name"/>
            <p><t t-esc="mahasiswa.jurusan or 'Jurusan belum diisi'"/> · Semester <t t-esc="mahasiswa.semester or '-'"/></p>
            <span class="mtz-badge-nim">NIM: <t t-esc="mahasiswa.nim or '-'"/></span>
          </div>
          <a href="/profile/edit" class="mtz-btn-hero">Edit Profil</a>
        </div>

        <div class="mtz-profile-grid">
          <section class="mtz-panel mtz-animate-up mtz-delay-1">
            <div class="mtz-panel-header compact"><div><h2>Informasi Dasar</h2><p>Identitas utama mahasiswa.</p></div></div>
            <div class="mtz-info-list">
              <div><span>Nama Lengkap</span><b t-esc="user.name"/></div>
              <div><span>Email</span><b t-esc="user.email or user.login"/></div>
              <div><span>NIM</span><b t-esc="mahasiswa.nim or 'Belum diisi'"/></div>
              <div><span>Jurusan</span><b t-esc="mahasiswa.jurusan or 'Belum diisi'"/></div>
              <div><span>Semester</span><b t-esc="mahasiswa.semester or 'Belum diisi'"/></div>
            </div>
          </section>

          <section class="mtz-panel mtz-animate-up mtz-delay-2">
            <div class="mtz-panel-header compact"><div><h2>Tujuan Karier</h2><p>Arah pengembangan diri.</p></div></div>
            <p class="mtz-profil-text" t-esc="mahasiswa.tujuan_karir or user.tujuan_karir or 'Belum diisi. Tambahkan tujuan karier agar mentor memahami kebutuhanmu.'"/>
          </section>

          <section class="mtz-panel mtz-animate-up mtz-delay-3">
            <div class="mtz-panel-header compact"><div><h2>Minat</h2><p>Bidang yang ingin kamu kembangkan.</p></div></div>
            <t t-if="mahasiswa.minat_ids"><div class="mtz-badge-list"><t t-foreach="mahasiswa.minat_ids" t-as="minat"><span class="mtz-badge-minat" t-esc="minat.name"/></t></div></t>
            <t t-else=""><div class="mtz-empty-small">Belum ada minat yang ditambahkan.</div></t>
          </section>

          <section class="mtz-panel mtz-animate-up mtz-delay-4">
            <div class="mtz-panel-header compact"><div><h2>Skill</h2><p>Kemampuan yang kamu miliki.</p></div></div>
            <t t-if="mahasiswa.skill_ids"><div class="mtz-badge-list"><t t-foreach="mahasiswa.skill_ids" t-as="skill"><span class="mtz-badge-skill" t-esc="skill.name"/></t></div></t>
            <t t-else=""><div class="mtz-empty-small">Belum ada skill yang ditambahkan.</div></t>
          </section>
        </div>
      </section>
    </main>
  </t>
</template>

<template id="page_edit_profil_mahasiswa" name="Edit Profil Mahasiswa">
  <t t-call="web.layout">
    <t t-set="head"><link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/></t>

    <main class="mtz-app-page">
      <nav class="mtz-app-nav mtz-animate-down">
        <a href="/dashboard" class="mtz-brand"><span class="mtz-logo-circle">M</span><span>Mentorize</span></a>
        <div class="mtz-app-menu"><a href="/dashboard">Dashboard</a><a href="/mentors">Cari Mentor</a><a href="/profile" class="active">Profil</a><a href="/history">Riwayat</a><a href="/chat">Chat</a></div>
        <div class="mtz-user-chip"><span class="mtz-avatar-circle"><t t-esc="user.name and user.name[:1].upper() or 'M'"/></span><span><b t-esc="user.name"/><small>Mahasiswa</small></span></div>
      </nav>

      <section class="mtz-dashboard-shell mtz-narrow-shell">
        <div class="mtz-form-header mtz-animate-up"><a href="/profile" class="mtz-back-link">← Kembali ke Profil</a><h1>Edit Profil Mahasiswa</h1><p>Lengkapi data agar sistem bisa memberikan rekomendasi mentor yang lebih sesuai.</p></div>

        <t t-if="error"><div class="mtz-alert-error"><t t-esc="error"/></div></t>

        <form action="/profile/update" method="post" class="mtz-panel mtz-form-card mtz-loading-form mtz-animate-up mtz-delay-1">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

          <div class="mtz-form-section">
            <h2>Informasi Dasar</h2>
            <div class="mtz-form-grid">
              <div class="mtz-form-group"><label>Nama Lengkap</label><input type="text" name="name" t-att-value="user.name" required="1"/></div>
              <div class="mtz-form-group"><label>NIM</label><input type="text" name="nim" t-att-value="mahasiswa.nim or ''" required="1"/></div>
              <div class="mtz-form-group"><label>Jurusan</label><input type="text" name="jurusan" t-att-value="mahasiswa.jurusan or ''" placeholder="Contoh: Teknologi Informasi"/></div>
              <div class="mtz-form-group"><label>Semester</label><input type="number" name="semester" min="1" max="14" t-att-value="mahasiswa.semester or ''" placeholder="Contoh: 4"/></div>
            </div>
          </div>

          <div class="mtz-form-section">
            <h2>Tujuan Karier</h2>
            <div class="mtz-form-group"><label>Ceritakan tujuan karier kamu</label><textarea name="tujuan_karir" rows="5" placeholder="Contoh: Saya ingin menjadi web developer dan memperdalam Odoo..."><t t-esc="mahasiswa.tujuan_karir or user.tujuan_karir or ''"/></textarea></div>
          </div>

          <div class="mtz-form-section">
            <h2>Minat</h2>
            <div class="mtz-checkbox-grid">
              <t t-foreach="all_minat" t-as="minat"><label class="mtz-checkbox-item"><input type="checkbox" name="minat_ids" t-att-value="minat.id" t-att-checked="minat.id in selected_minat_ids and 'checked' or None"/><span t-esc="minat.name"/></label></t>
            </div>
          </div>

          <div class="mtz-form-section">
            <h2>Skill</h2>
            <div class="mtz-checkbox-grid">
              <t t-foreach="all_skill" t-as="skill"><label class="mtz-checkbox-item"><input type="checkbox" name="skill_ids" t-att-value="skill.id" t-att-checked="skill.id in selected_skill_ids and 'checked' or None"/><span t-esc="skill.name"/></label></t>
            </div>
          </div>

          <div class="mtz-form-actions"><button type="submit" class="mtz-btn-primary mtz-btn-fit">Simpan Perubahan</button><a href="/profile" class="mtz-btn-secondary mtz-btn-fit">Batal</a></div>
        </form>
      </section>
    </main>
  </t>
</template>
</data>
</odoo>
