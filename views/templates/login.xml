<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
<template id="page_login" name="Mentorize Login">
  <t t-call="web.layout">
    <t t-set="head">
      <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
    </t>

    <main class="mtz-auth-page">
      <section class="mtz-auth-visual mtz-animate-left">
        <div class="mtz-auth-visual-inner">
          <img src="/mentorize/static/src/img/mentorize-illustration.svg" alt="Mentorize"/>
          <h2>Satu Platform, Dua Peran</h2>
          <p>Masuk sebagai mahasiswa atau alumni untuk melanjutkan mentoring dan pengembangan karier Anda.</p>
        </div>
      </section>

      <section class="mtz-auth-panel mtz-animate-right">
        <div class="mtz-auth-card">
          <a class="mtz-logo" href="/">
            <span class="mtz-logo-circle">M</span>
            <span>Mentorize</span>
          </a>
          <h1>Masuk ke Mentorize</h1>
          <p class="mtz-subtitle">Lanjutkan perjalanan mentoring Anda</p>

          <t t-if="error">
            <div class="mtz-alert-error"><t t-esc="error"/></div>
          </t>

          <form action="/mentorize/login/submit" method="post" class="mtz-form mtz-loading-form">
            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
            <input type="hidden" name="role" id="input-role" value="mahasiswa"/>

            <p class="mtz-role-label">Masuk Sebagai</p>
            <div class="mtz-role-grid">
              <div class="mtz-role-card active" id="role-mahasiswa" onclick="selectRole('mahasiswa')">
                <div class="mtz-role-icon">🎓</div>
                <div class="mtz-role-name">Mahasiswa</div>
                <div class="mtz-role-desc">Cari mentor &amp; kembangkan skill</div>
              </div>
              <div class="mtz-role-card" id="role-alumni" onclick="selectRole('alumni')">
                <div class="mtz-role-icon">⭐</div>
                <div class="mtz-role-name">Alumni</div>
                <div class="mtz-role-desc">Bagikan pengalaman &amp; mentor</div>
              </div>
            </div>

            <div class="mtz-form-group">
              <label>Email</label>
              <input type="email" name="email" placeholder="nama@email.com" required="1" autocomplete="email"/>
            </div>
            <div class="mtz-form-group">
              <label id="identity-label">NIM</label>
              <input type="text" name="identity" id="identity-input" placeholder="Masukkan NIM Anda" autocomplete="off"/>
            </div>
            <div class="mtz-form-group">
              <label>Password</label>
              <input type="password" name="password" placeholder="••••••••" required="1" autocomplete="current-password"/>
            </div>

            <div class="mtz-form-row">
              <label class="mtz-remember"><input type="checkbox" name="remember"/> Ingat saya</label>
              <a href="/mentorize/forgot-password" class="mtz-forgot">Lupa password?</a>
            </div>

            <button type="submit" class="mtz-btn-primary" id="btn-login">Masuk sebagai Mahasiswa</button>
          </form>

          <div class="mtz-divider"><span>atau</span></div>
          <p class="mtz-register-link">Belum punya akun? <a href="/mentorize/register">Daftar sekarang</a></p>
        </div>
      </section>
    </main>

    <script>
      function selectRole(role) {
        document.getElementById('role-mahasiswa').classList.remove('active');
        document.getElementById('role-alumni').classList.remove('active');
        document.getElementById('role-' + role).classList.add('active');
        document.getElementById('input-role').value = role;
        var identityLabel = document.getElementById('identity-label');
        var identityInput = document.getElementById('identity-input');
        var btnLogin = document.getElementById('btn-login');
        if (role === 'mahasiswa') {
          identityLabel.textContent = 'NIM';
          identityInput.placeholder = 'Masukkan NIM Anda';
          btnLogin.textContent = 'Masuk sebagai Mahasiswa';
        } else {
          identityLabel.textContent = 'KAPA';
          identityInput.placeholder = 'Masukkan KAPA Anda';
          btnLogin.textContent = 'Masuk sebagai Alumni';
        }
      }
    </script>
  </t>
</template>
</data>
</odoo>