<odoo>
    <template id="page_profil_mahasiswa" name="Profil Mahasiswa">
        <t t-call="website.layout">

            <div class="container mt-5 mb-5">

                <div class="card shadow-sm p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <div>
                            <h1>Profil Mahasiswa</h1>
                            <p class="text-muted mb-0">
                                Informasi profil mahasiswa
                            </p>
                        </div>

                        <a href="/mentorize/mahasiswa/profil/edit"
                           class="btn btn-primary">
                            Edit Profil
                        </a>

                    </div>

                    <hr/>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <strong>Nama</strong>
                            <p>
                                <t t-esc="user.name"/>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Email</strong>
                            <p>
                                <t t-esc="user.email"/>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>NIM</strong>
                            <p>
                                <t t-esc="mahasiswa.nim or '-'"/>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Jurusan</strong>
                            <p>
                                <t t-esc="mahasiswa.jurusan or '-'"/>
                            </p>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>Semester</strong>
                            <p>
                                <t t-esc="mahasiswa.semester or '-'"/>
                            </p>
                        </div>

                        <div class="col-md-12 mb-3">
                            <strong>Tujuan Karir</strong>
                            <p>
                                <t t-esc="user.tujuan_karir or '-'"/>
                            </p>
                        </div>

                    </div>

                    <hr/>

                    <h4>Minat</h4>

                    <div class="mb-4">

                        <t t-if="mahasiswa.minat_ids">

                            <t t-foreach="mahasiswa.minat_ids" t-as="minat">
                                <span class="badge bg-primary me-2 mb-2">
                                    <t t-esc="minat.name"/>
                                </span>
                            </t>

                        </t>

                        <t t-if="not mahasiswa.minat_ids">
                            <p class="text-muted">
                                Belum ada minat.
                            </p>
                        </t>

                    </div>

                    <h4>Skill</h4>

                    <div>

                        <t t-if="mahasiswa.skill_ids">

                            <t t-foreach="mahasiswa.skill_ids" t-as="skill">
                                <span class="badge bg-success me-2 mb-2">
                                    <t t-esc="skill.name"/>
                                </span>
                            </t>

                        </t>

                        <t t-if="not mahasiswa.skill_ids">
                            <p class="text-muted">
                                Belum ada skill.
                            </p>
                        </t>

                    </div>

                </div>

            </div>

        </t>
    </template>
</odoo>