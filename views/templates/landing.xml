<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
<template id="page_landing" name="Mentorize Landing Page">
  <t t-call="web.layout">
    <t t-set="head">
      <link rel="stylesheet" href="/mentorize/static/src/css/mentorize.css"/>
    </t>

    <main class="mtz-page mtz-landing-page">
      <nav class="mtz-public-nav mtz-animate-down">
        <a href="/" class="mtz-brand">
          <span class="mtz-logo-circle">M</span>
          <span>Mentorize</span>
        </a>
        <div class="mtz-public-links">
          <a href="#fitur">Fitur</a>
          <a href="#alur">Alur</a>
          <a href="/login" class="mtz-nav-login">Masuk</a>
          <a href="/register" class="mtz-btn-small">Daftar</a>
        </div>
      </nav>

      <section class="mtz-landing-hero">
        <div class="mtz-landing-copy mtz-animate-up">
          <span class="mtz-kicker">Platform Mentorship Alumni-Mahasiswa</span>
          <h1>Satu Platform, Dua Peran untuk Bertumbuh Bersama</h1>
          <p>Mentorize membantu mahasiswa menemukan alumni mentor yang sesuai dengan minat, skill, dan tujuan karier. Proses mentoring jadi lebih rapi mulai dari profil, rekomendasi mentor, request, jadwal, sampai evaluasi.</p>
          <div class="mtz-landing-actions">
            <a href="/login" class="mtz-btn-primary mtz-btn-fit">Masuk ke Mentorize</a>
            <a href="/register" class="mtz-btn-secondary mtz-btn-fit">Buat Akun Baru</a>
          </div>
          <div class="mtz-landing-metrics">
            <div><strong>3</strong><span>Role pengguna</span></div>
            <div><strong>24/7</strong><span>Akses platform</span></div>
            <div><strong>5s</strong><span>Target matching</span></div>
          </div>
        </div>
        <div class="mtz-landing-visual mtz-animate-float">
          <img src="/mentorize/static/src/img/mentorize-illustration.svg" alt="Ilustrasi Mentorize"/>
        </div>
      </section>

      <section id="fitur" class="mtz-feature-section">
        <div class="mtz-section-heading">
          <span class="mtz-kicker">Fitur Utama</span>
          <h2>Dibuat sesuai kebutuhan SRS Mentorize</h2>
        </div>
        <div class="mtz-feature-grid">
          <div class="mtz-feature-card mtz-animate-card"><span>🎓</span><h3>Profil Mahasiswa</h3><p>Isi minat, skill, jurusan, semester, dan tujuan karier agar rekomendasi mentor lebih tepat.</p></div>
          <div class="mtz-feature-card mtz-animate-card"><span>⭐</span><h3>Profil Alumni</h3><p>Alumni dapat mengatur pengalaman, skill, ketersediaan, dan permintaan mentoring.</p></div>
          <div class="mtz-feature-card mtz-animate-card"><span>🤝</span><h3>Matchmaking</h3><p>Sistem menampilkan rekomendasi mentor berdasarkan kesesuaian data profil.</p></div>
          <div class="mtz-feature-card mtz-animate-card"><span>📅</span><h3>Jadwal &amp; Riwayat</h3><p>Monitoring state request, sesi terjadwal, sesi selesai, dan progress mentoring.</p></div>
        </div>
      </section>

      <section id="alur" class="mtz-flow-section">
        <div class="mtz-section-heading">
          <span class="mtz-kicker">Alur Singkat</span>
          <h2>Mulai mentoring dalam beberapa langkah</h2>
        </div>
        <div class="mtz-flow-grid">
          <div><b>1</b><h3>Daftar / Login</h3><p>Pilih role mahasiswa atau alumni.</p></div>
          <div><b>2</b><h3>Lengkapi Profil</h3><p>Isi data yang dibutuhkan untuk proses matching.</p></div>
          <div><b>3</b><h3>Pilih Mentor</h3><p>Lihat rekomendasi dan ajukan request mentoring.</p></div>
          <div><b>4</b><h3>Mulai Mentoring</h3><p>Lanjutkan ke jadwal, chat, dan feedback.</p></div>
        </div>
      </section>
    </main>
  </t>
</template>
</data>
</odoo>
