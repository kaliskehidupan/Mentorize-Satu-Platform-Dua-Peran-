<odoo>
    <template id="page_detail_mentor" name="Detail Mentor">
        <t t-call="website.layout">

            <div class="container mt-5 mb-5">

                <!-- Header Mentor -->
                <div class="card shadow-sm p-4 mb-4">
                    <div class="row align-items-center">

                        <div class="col-md-3 text-center">
                            <img t-if="alumni.user_id.image_1920"
                                 t-att-src="'/web/image/res.users/%s/image_1920' % alumni.user_id.id"
                                 class="img-fluid rounded-circle"
                                 style="width:150px;height:150px;object-fit:cover;"/>

                            <img t-if="not alumni.user_id.image_1920"
                                 src="/web/static/img/placeholder.png"
                                 class="img-fluid rounded-circle"
                                 style="width:150px;height:150px;object-fit:cover;"/>
                        </div>

                        <div class="col-md-9">
                            <h2>
                                <t t-esc="alumni.user_id.name"/>
                            </h2>

                            <p class="text-muted mb-1">
                                Alumni Mentor
                            </p>

                            <p>
                                <strong>Ketersediaan:</strong>
                                <t t-esc="alumni.ketersediaan"/>
                            </p>

                            <p t-if="match_info">
                                <strong>Match Score:</strong>
                                <t t-esc="match_info.score"/>%
                            </p>
                        </div>

                    </div>
                </div>

                <!-- Informasi Mentor -->
                <div class="card shadow-sm p-4 mb-4">
                    <h4 class="mb-3">Informasi Mentor</h4>

                    <p>
                        <strong>Email:</strong>
                        <t t-esc="alumni.user_id.email"/>
                    </p>

                    <p t-if="alumni.bio">
                        <strong>Bio:</strong><br/>
                        <t t-esc="alumni.bio"/>
                    </p>

                    <p t-if="alumni.keahlian">
                        <strong>Keahlian:</strong>
                        <t t-esc="alumni.keahlian"/>
                    </p>
                </div>

                <!-- Form Request Mentoring -->
                <div class="card shadow-sm p-4 mb-4">

                    <h4 class="mb-3">Ajukan Mentoring</h4>

                    <t t-if="existing_request">
                        <div class="alert alert-warning">
                            Kamu sudah pernah mengajukan mentoring kepada mentor ini.
                        </div>
                    </t>

                    <t t-if="not existing_request">

                        <form t-att-action="'/mentorize/mentor/request/%s' % alumni.id"
                              method="post">

                            <div class="mb-3">
                                <label class="form-label">
                                    Topik Mentoring
                                </label>

                                <input type="text"
                                       name="topik"
                                       class="form-control"
                                       required="required"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">
                                    Deskripsi
                                </label>

                                <textarea name="deskripsi"
                                          class="form-control"
                                          rows="5"></textarea>
                            </div>

                            <button type="submit"
                                    class="btn btn-primary">
                                Kirim Request
                            </button>

                        </form>

                    </t>

                </div>

                <!-- Feedback -->
                <div class="card shadow-sm p-4">

                    <h4 class="mb-4">Feedback Mentor</h4>

                    <t t-if="feedbacks">

                        <t t-foreach="feedbacks" t-as="fb">

                            <div class="border rounded p-3 mb-3">

                                <h6>
                                    <t t-esc="fb.mahasiswa_id.user_id.name"/>
                                </h6>

                                <p class="mb-1">
                                    Rating:
                                    <t t-esc="fb.rating"/> / 5
                                </p>

                                <p class="mb-0">
                                    <t t-esc="fb.komentar"/>
                                </p>

                            </div>

                        </t>

                    </t>

                    <t t-if="not feedbacks">
                        <p class="text-muted">
                            Belum ada feedback.
                        </p>
                    </t>

                </div>

            </div>

        </t>
    </template>
</odoo>