<odoo>
    <template id="page_riwayat_mahasiswa" name="Riwayat Mentoring Mahasiswa">
        <t t-call="website.layout">

            <div class="container mt-5 mb-5">

                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1>Riwayat Mentoring</h1>
                        <p class="text-muted mb-0">
                            Daftar permintaan mentoring mahasiswa
                        </p>
                    </div>

                    <a href="/mentorize/mentor"
                       class="btn btn-primary">
                        Cari Mentor
                    </a>
                </div>

                <!-- Alert Success -->
                <t t-if="success">
                    <div class="alert alert-success">
                        Request mentoring berhasil dikirim.
                    </div>
                </t>

                <!-- Jika Tidak Ada Riwayat -->
                <t t-if="not requests">
                    <div class="card shadow-sm p-5 text-center">
                        <h4>Belum Ada Riwayat Mentoring</h4>

                        <p class="text-muted">
                            Kamu belum pernah mengajukan mentoring.
                        </p>

                        <a href="/mentorize/mentor"
                           class="btn btn-primary mt-3">
                            Temukan Mentor
                        </a>
                    </div>
                </t>

                <!-- List Riwayat -->
                <t t-if="requests">

                    <div class="row">

                        <t t-foreach="requests" t-as="req">

                            <div class="col-md-6 mb-4">

                                <div class="card shadow-sm h-100">

                                    <div class="card-body">

                                        <div class="d-flex justify-content-between align-items-start mb-3">

                                            <div>
                                                <h5 class="card-title mb-1">
                                                    <t t-esc="req.topik"/>
                                                </h5>

                                                <p class="text-muted mb-0">
                                                    Mentor:
                                                    <t t-esc="req.alumni_id.user_id.name"/>
                                                </p>
                                            </div>

                                            <!-- Status Badge -->
                                            <div>
                                                <span t-if="req.status == 'pending'"
                                                      class="badge bg-warning text-dark">
                                                    Pending
                                                </span>

                                                <span t-if="req.status == 'approved'"
                                                      class="badge bg-success">
                                                    Approved
                                                </span>

                                                <span t-if="req.status == 'rejected'"
                                                      class="badge bg-danger">
                                                    Rejected
                                                </span>
                                            </div>

                                        </div>

                                        <!-- Deskripsi -->
                                        <p class="card-text">
                                            <t t-esc="req.deskripsi or '-'"/>
                                        </p>

                                        <!-- Tanggal -->
                                        <small class="text-muted">
                                            Tanggal Request:
                                            <t t-esc="req.tanggal_request"/>
                                        </small>

                                    </div>

                                </div>

                            </div>

                        </t>

                    </div>

                </t>

            </div>

        </t>
    </template>
</odoo>