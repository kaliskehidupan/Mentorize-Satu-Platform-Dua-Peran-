<odoo>
    <template id="page_list_mentor" name="List Mentor">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h1>Daftar Mentor</h1>

                <t t-foreach="alumni_list" t-as="mentor">
                    <div class="card mb-3 p-3">
                        <h4>
                            <t t-esc="mentor.user_id.name"/>
                        </h4>

                        <p>
                            Skill Match:
                            <t t-esc="matchmaking_data.get(mentor.id, {}).get('skill_match', 0)"/>
                        </p>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>