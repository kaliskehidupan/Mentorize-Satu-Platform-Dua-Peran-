<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ===================== GROUPS ===================== -->
        <record id="group_mentorize_mahasiswa" model="res.groups">
            <field name="name">Mahasiswa</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_mentorize_alumni" model="res.groups">
            <field name="name">Alumni</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_mentorize_admin" model="res.groups">
            <field name="name">Admin Mentorize</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <!-- ===================== RECORD RULES ===================== -->
        <record id="rule_mahasiswa_own_profile" model="ir.rule">
            <field name="name">Mahasiswa: hanya lihat profil sendiri</field>
            <field name="model_id" ref="model_mentorize_mahasiswa"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_mentorize_mahasiswa'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_mahasiswa_own_request" model="ir.rule">
            <field name="name">Mahasiswa: hanya lihat request sendiri</field>
            <field name="model_id" ref="model_mentorize_request"/>
            <field name="domain_force">[('mahasiswa_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_mentorize_mahasiswa'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

