<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    <record id="module_category_mentorize" model="ir.module.category">
      <field name="name">Mentorize</field>
      <field name="description">Akses pengguna platform Mentorize</field>
      <field name="sequence">20</field>
    </record>

    <record id="group_mentorize_mahasiswa" model="res.groups">
      <field name="name">Mahasiswa Mentorize</field>
      <field name="category_id" ref="mentorize.module_category_mentorize"/>
    </record>

    <record id="group_mentorize_alumni" model="res.groups">
      <field name="name">Alumni Mentorize</field>
      <field name="category_id" ref="mentorize.module_category_mentorize"/>
    </record>

    <record id="group_mentorize_admin" model="res.groups">
      <field name="name">Admin Mentorize</field>
      <field name="category_id" ref="mentorize.module_category_mentorize"/>
      <field name="implied_ids" eval="[(4, ref('mentorize.group_mentorize_mahasiswa')), (4, ref('mentorize.group_mentorize_alumni'))]"/>
    </record>
  </data>
</odoo>
